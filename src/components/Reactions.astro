<script define:vars={{ slug, supabaseUrl, supabaseKey }}>
  // Use window-scoped state so it persists across View Transition re-executions
  if (!window.__reactionsState) {
    window.__reactionsState = {
      currentSlug: "",
      serverCounts: [],
      userReactions: [],
      pickerOpen: false,
      controller: null,
    };
  }
  const _rs = window.__reactionsState;

  async function supabaseRpc(fnName, params) {
    const res = await fetch(`${supabaseUrl}/rest/v1/rpc/${fnName}`, {
      method: "POST",
      headers: {
        "apikey": supabaseKey,
        "Content-Type": "application/json",
      },
      body: JSON.stringify(params),
    });
    if (!res.ok) throw new Error(`Supabase RPC ${fnName} failed: ${res.status}`);
    return res.json();
  }

  function getLocalReactions(s) {
    try {
      return JSON.parse(localStorage.getItem(`reactions:${s}`) || "[]");
    } catch { return []; }
  }

  function setLocalReactions(s, arr) {
    localStorage.setItem(`reactions:${s}`, JSON.stringify(arr));
  }

  function renderReactions() {
    const bar = document.getElementById("reactions-bar");
    const addBtn = document.getElementById("reaction-add-btn");
    if (!bar || !addBtn) return;

    // Remove existing emoji buttons (keep add button)
    bar.querySelectorAll(":scope > .reaction-btn").forEach(b => b.remove());

    // Insert emoji buttons before the add button
    for (const { emoji, count } of _rs.serverCounts) {
      if (count <= 0) continue;
      const btn = document.createElement("button");
      btn.className = "reaction-btn";
      if (_rs.userReactions.includes(emoji)) btn.classList.add("reaction-mine");
      btn.setAttribute("aria-label", `${emoji} ${count}`);
      btn.setAttribute("title", `${emoji} ${count}`);
      btn.dataset.emoji = emoji;
      btn.innerHTML = `<span class="reaction-emoji">${emoji}</span><span class="reaction-count">${count}</span>`;
      bar.insertBefore(btn, addBtn);
    }

    // Hide add button when user already has a reaction
    const hasReacted = _rs.userReactions.length > 0;
    addBtn.hidden = hasReacted;
  }

  async function handleToggle(emoji) {
    const isOwn = _rs.userReactions.includes(emoji);
    const prevEmoji = _rs.userReactions.length > 0 ? _rs.userReactions[0] : null;

    if (isOwn) {
      // Un-react: remove the current reaction
      _rs.userReactions = [];
      const existing = _rs.serverCounts.find(r => r.emoji === emoji);
      if (existing) {
        existing.count = Math.max(existing.count - 1, 0);
        if (existing.count === 0) _rs.serverCounts = _rs.serverCounts.filter(r => r.emoji !== emoji);
      }
      setLocalReactions(_rs.currentSlug, _rs.userReactions);
      renderReactions();

      try {
        const updated = await supabaseRpc("toggle_reaction", {
          p_slug: _rs.currentSlug, p_emoji: emoji, p_action: "remove",
        });
        _rs.serverCounts = updated;
        renderReactions();
      } catch {
        _rs.userReactions = [emoji];
        const ex = _rs.serverCounts.find(r => r.emoji === emoji);
        if (ex) ex.count += 1; else _rs.serverCounts.push({ emoji, count: 1 });
        setLocalReactions(_rs.currentSlug, _rs.userReactions);
        renderReactions();
      }
    } else {
      // Switch reaction: remove old (if any), then add new
      // Optimistic UI — remove old
      if (prevEmoji) {
        const old = _rs.serverCounts.find(r => r.emoji === prevEmoji);
        if (old) {
          old.count = Math.max(old.count - 1, 0);
          if (old.count === 0) _rs.serverCounts = _rs.serverCounts.filter(r => r.emoji !== prevEmoji);
        }
      }
      // Optimistic UI — add new
      _rs.userReactions = [emoji];
      const existing = _rs.serverCounts.find(r => r.emoji === emoji);
      if (existing) existing.count += 1;
      else _rs.serverCounts.push({ emoji, count: 1 });
      setLocalReactions(_rs.currentSlug, _rs.userReactions);
      renderReactions();

      try {
        // Remove old reaction on server first
        if (prevEmoji) {
          await supabaseRpc("toggle_reaction", {
            p_slug: _rs.currentSlug, p_emoji: prevEmoji, p_action: "remove",
          });
        }
        // Add new reaction
        const updated = await supabaseRpc("toggle_reaction", {
          p_slug: _rs.currentSlug, p_emoji: emoji, p_action: "add",
        });
        _rs.serverCounts = updated;
        renderReactions();
      } catch {
        // Revert: restore old, remove new
        _rs.userReactions = prevEmoji ? [prevEmoji] : [];
        const ex = _rs.serverCounts.find(r => r.emoji === emoji);
        if (ex) { ex.count -= 1; if (ex.count <= 0) _rs.serverCounts = _rs.serverCounts.filter(r => r.emoji !== emoji); }
        if (prevEmoji) {
          const old = _rs.serverCounts.find(r => r.emoji === prevEmoji);
          if (old) old.count += 1; else _rs.serverCounts.push({ emoji: prevEmoji, count: 1 });
        }
        setLocalReactions(_rs.currentSlug, _rs.userReactions);
        renderReactions();
      }
    }
  }

  function togglePicker() {
    const picker = document.getElementById("reaction-picker");
    if (!picker) return;
    _rs.pickerOpen = !_rs.pickerOpen;
    picker.hidden = !_rs.pickerOpen;
    if (_rs.pickerOpen) {
      const search = document.getElementById("picker-search");
      if (search) { search.value = ""; filterEmojis(""); }
    }
  }

  function closePicker() {
    const picker = document.getElementById("reaction-picker");
    if (!picker) return;
    _rs.pickerOpen = false;
    picker.hidden = true;
  }

