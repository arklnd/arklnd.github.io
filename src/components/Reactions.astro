  function filterEmojis(query) {
    const grid = document.getElementById("picker-scroll");
    const noResults = document.getElementById("picker-no-results");
    if (!grid) return;
    const q = query.toLowerCase().trim();
    const labels = grid.querySelectorAll(".picker-group-label");
    const buttons = grid.querySelectorAll(".picker-emoji");
    let anyVisible = false;

    buttons.forEach(btn => {
      if (!q) { btn.hidden = false; anyVisible = true; return; }
      const emoji = btn.dataset.emoji;
      const name = (emojiNames[emoji] || "").toLowerCase();
      const match = name.includes(q) || emoji.includes(q);
      btn.hidden = !match;
      if (match) anyVisible = true;
    });

    // Show/hide group labels based on whether any emoji in the group is visible
    labels.forEach(label => {
      if (!q) { label.hidden = false; return; }
      let sibling = label.nextElementSibling;
      let groupHasVisible = false;
      while (sibling && !sibling.classList.contains("picker-group-label")) {
        if (sibling.classList.contains("picker-emoji") && !sibling.hidden) {
          groupHasVisible = true;
        }
        sibling = sibling.nextElementSibling;
      }
      label.hidden = !groupHasVisible;
    });

    if (noResults) noResults.hidden = anyVisible;
  }

  function setup() {
    // Abort previous listeners to prevent duplicates on View Transition navigations
    if (_rs.controller) _rs.controller.abort();
    _rs.controller = new AbortController();
    const signal = _rs.controller.signal;

    const section = document.querySelector(".reactions");
    if (!section) return;

    _rs.currentSlug = section.dataset.slug || "";
    _rs.userReactions = getLocalReactions(_rs.currentSlug);
    _rs.pickerOpen = false;

    // Fetch server counts
    supabaseRpc("get_reactions", { p_slug: _rs.currentSlug })
      .then(data => { _rs.serverCounts = data || []; renderReactions(); })
      .catch(() => { _rs.serverCounts = []; renderReactions(); });

    // Add button click
    const addBtn = document.getElementById("reaction-add-btn");
    if (addBtn) addBtn.addEventListener("click", togglePicker, { signal });

    // Picker search input
    const searchInput = document.getElementById("picker-search");
    if (searchInput) {
      searchInput.addEventListener("input", (e) => filterEmojis(e.target.value), { signal });
      searchInput.addEventListener("keydown", (e) => e.stopPropagation(), { signal });
    }

    // Bar emoji clicks (delegation)
    const bar = document.getElementById("reactions-bar");
    if (bar) {
      bar.addEventListener("click", (e) => {
        const btn = e.target.closest(".reaction-btn");
        if (!btn) return;
        const emoji = btn.dataset.emoji;
        if (emoji) {
          // Animate
          btn.classList.add("reaction-pop");
          btn.addEventListener("animationend", () => btn.classList.remove("reaction-pop"), { once: true });
          handleToggle(emoji);
        }
      }, { signal });
    }

    // Picker emoji clicks
    const picker = document.getElementById("reaction-picker");
    if (picker) {
      picker.addEventListener("click", (e) => {
        const btn = e.target.closest(".picker-emoji");
        if (!btn) return;
        const emoji = btn.dataset.emoji;
        if (emoji) {
          closePicker();
          handleToggle(emoji);
        }
      }, { signal });
    }

    // Close picker on outside click
    document.addEventListener("click", (e) => {
      if (!_rs.pickerOpen) return;
      const picker = document.getElementById("reaction-picker");
      const addBtn = document.getElementById("reaction-add-btn");
      if (picker && addBtn && !picker.contains(e.target) && !addBtn.contains(e.target)) {
        closePicker();
      }
    }, { signal });

    // Close picker on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && _rs.pickerOpen) closePicker();
    }, { signal });

    renderReactions();
  }

  document.addEventListener("astro:page-load", setup);
</script>

