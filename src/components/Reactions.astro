        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="16"/>
        <line x1="8" y1="12" x2="16" y2="12"/>
      </svg>
      <span class="reaction-add-label">React</span>
    </button>
  </div>
  <div class="reaction-picker" id="reaction-picker" hidden>
    <input type="text" class="picker-search" id="picker-search" placeholder="Search emoji..." autocomplete="off" />
