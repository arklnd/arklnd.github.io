---
interface Props {
  slug: string;
}

const { slug } = Astro.props;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<span class="reaction-badge" data-slug={slug}></span>

<script define:vars={{ supabaseUrl, supabaseKey }}>
  let loaded = false;
  let allReactions = new Map();

  async function fetchAllReactions() {
    if (loaded) return;
    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/rpc/get_all_reactions`, {
        method: "POST",
        headers: {
          "apikey": supabaseKey,
          "Content-Type": "application/json",
        },
        body: "{}",
      });
      if (!res.ok) return;
      const data = await res.json();

      // Group by post_slug
      for (const row of data) {
        if (!allReactions.has(row.post_slug)) {
          allReactions.set(row.post_slug, []);
        }
        allReactions.get(row.post_slug).push({ emoji: row.emoji, count: row.count });
      }
      loaded = true;
    } catch {
      // Silently fail
    }
  }

  function renderBadges() {
    const badges = document.querySelectorAll(".reaction-badge");
    for (const badge of badges) {
      const slug = badge.dataset.slug;
      if (!slug) continue;
      const reactions = allReactions.get(slug);
      if (reactions && reactions.length > 0) {
        // Show top 3 reactions
        const top = reactions.slice(0, 3);
        badge.textContent = top.map(r => `${r.emoji}\u2009${r.count}`).join("  ");
        badge.classList.remove("badge-empty");
      } else {
        badge.textContent = "";
        badge.classList.add("badge-empty");
      }
    }
  }

  async function setup() {
    await fetchAllReactions();
    renderBadges();
  }

  document.addEventListener("astro:page-load", setup);
</script>

<style>
  .reaction-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    line-height: 1;
    letter-spacing: 0.02em;
    min-height: 1em;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.25em 0.6em 0.25em 0.4em;
    width: fit-content;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }

  .reaction-badge:empty,
  .reaction-badge.badge-empty {
    display: none;
  }

  .pc:hover .reaction-badge {
    opacity: 1;
  }
</style>
