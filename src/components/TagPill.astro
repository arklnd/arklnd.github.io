---
import { getCollection } from "astro:content";

interface Props {
  tag: string;
  /** "default" = home/tags pages, "small" = article header, "micro" = PostCard inline */
  size?: "default" | "small" | "micro";
}

const { tag, size = "default" } = Astro.props;

const label = tag.replace(/-/g, " ").toUpperCase();

let count: number | null = null;
if (size !== "micro") {
  const posts = await getCollection("posts");
  count = posts.filter((p) => p.data.tags.includes(tag)).length;
}
---

{size === "micro" ? (
  <span class="tp tp--micro">{label}</span>
) : (
  <a href={`/tags/${tag}`} class:list={["tp", size === "small" && "tp--sm"]}>
    <span class="tp-name">{label}</span>
    <span class="tp-count">{count}</span>
  </a>
)}

<style>
  .tp {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    background: var(--color-surface);
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }

  .tp:hover {
    border-color: var(--color-link);
    color: var(--color-link);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .tp-count {
    font-size: 0.6875rem;
    font-weight: 700;
    min-width: 1.35rem;
    height: 1.35rem;
    padding: 0 0.3rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-link) 12%, transparent);
    color: var(--color-link);
  }

  /* ── Small variant (article header) ─── */
  .tp--sm {
    padding: 0.15rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 600;
    border: none;
    background: color-mix(in srgb, var(--color-link) 10%, transparent);
    color: var(--color-link);
    border-radius: 12px;
  }

  .tp--sm:hover {
    background: color-mix(in srgb, var(--color-link) 20%, transparent);
    color: var(--color-link);
    box-shadow: none;
  }

  .tp--sm .tp-count {
    font-size: 0.55rem;
    font-weight: 700;
    padding: 0;
    background: none;
    color: inherit;
    opacity: 0.7;
    vertical-align: super;
    line-height: 1;
    position: relative;
    top: -0.3em;
  }

  /* ── Micro variant (PostCard inline) ─── */
  .tp--micro {
    padding: 0.1rem 0.45rem;
    font-size: 0.625rem;
    font-weight: 600;
    border: none;
    background: color-mix(in srgb, var(--color-link) 8%, transparent);
    color: var(--color-link);
    border-radius: 10px;
    white-space: nowrap;
  }
</style>
