---
import Heading from "./Heading.astro";
import Prose from "./Prose.astro";

interface Props {
  title: string;
  date: Date;
  description: string;
  readingTime?: string;
  postId?: string;
  slug?: string;
}

const { title, date, description, readingTime, postId, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<!-- VSCode-style sticky scroll bar -->
<div id="sticky-scroll-bar" class="sticky-scroll-bar" aria-label="Current section" role="navigation">
  <div id="sticky-scroll-crumbs" class="sticky-scroll-crumbs"></div>
</div>

<article class="article">
  <header class="article-header">
    <Heading as="h1" transition:name={slug ? `post-title-${slug}` : undefined}>{title}</Heading>
    <p class="article-meta">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon"
        ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line
          x1="16"
          y1="2"
          x2="16"
          y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line
          x1="3"
          y1="10"
          x2="21"
          y2="10"></line></svg
      >
      <time datetime={date.toISOString()} transition:name={slug ? `post-date-${slug}` : undefined}>{formattedDate}</time>
      {
        readingTime && (
          <>
            <span class="separator"> — </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon"
            >
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            <span class="article-reading-time">{readingTime}</span>
          </>
        )
      }
    </p>
  </header>
  <Prose>
    <slot />
  </Prose>
  {postId && (
    <div class="article-hits">
      <img id="hits-badge" alt="Hits" data-post-id={postId} />
    </div>
  )}
  <script>
    const badge = document.getElementById('hits-badge');
    if (badge) {
      const id = badge.dataset.postId;
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const color = isDark ? '6ba3f5' : '3d6aa8';
      const label = isDark ? '333331' : '525d68';
      badge.src = `https://hits.sh/knhs.in/${id}.svg?style=plastic&color=${color}&labelColor=${label}`;
    }
  </script>
</article>

<div class="floating-buttons">
  <!-- Collapsible utility buttons -->
  <div id="float-more-group" class="float-more-group">
    <button id="float-sticky-toggle" class="float-btn" aria-label="Toggle sticky scroll" title="Toggle sticky scroll">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="5" x2="21" y2="5"></line>
        <line x1="3" y1="10" x2="14" y2="10"></line>
        <line x1="3" y1="15" x2="17" y2="15"></line>
        <line x1="3" y1="20" x2="12" y2="20"></line>
      </svg>
    </button>
  <button id="float-width-toggle" class="float-btn" aria-label="Toggle reading width" title="Toggle reading width">
    <svg class="icon-expand" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="15 3 21 3 21 9"></polyline>
      <polyline points="9 21 3 21 3 15"></polyline>
      <line x1="21" y1="3" x2="14" y2="10"></line>
      <line x1="3" y1="21" x2="10" y2="14"></line>
    </svg>
    <svg class="icon-compress" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="4 14 10 14 10 20"></polyline>
      <polyline points="20 10 14 10 14 4"></polyline>
      <line x1="10" y1="14" x2="3" y2="21"></line>
      <line x1="21" y1="3" x2="14" y2="10"></line>
    </svg>
  </button>
  <button id="float-theme-toggle" class="float-btn" aria-label="Toggle theme" title="Toggle dark / light mode">
    <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
    <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>
  </div><!-- /float-more-group -->
  <!-- Always-visible: more toggle + scroll -->
  <button id="float-more-toggle" class="float-btn" aria-label="More options" title="More options">
    <svg class="icon-more-open" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/>
    </svg>
    <svg class="icon-more-close" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
  <button id="scroll-toggle" class="float-btn" aria-label="Scroll to bottom" title="Scroll to bottom">
    <svg class="icon-up" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="18 15 12 9 6 15"></polyline>
    </svg>
    <svg class="icon-down" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>
</div>

<style>
  .article {
    max-width: var(--width-content);
    transition: max-width 0.25s ease;
  }

  :global(html[data-wide="true"]) .article {
    max-width: var(--width-page);
  }

  .article-header {
    margin-bottom: var(--space-xl);
  }

  .article-meta {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-sm);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .icon {
    display: inline-block;
    vertical-align: middle;
    margin-right: -0.25rem;
    position: relative;
    top: -2px;
  }

  .separator {
    color: var(--color-text-tertiary);
    margin: 0 0.125rem;
  }

  .article-meta {
    justify-content: flex-start;
  }

  .article-hits {
    margin-top: var(--space-xl);
    display: flex;
    justify-content: center;
  }

  /* ── Sticky scroll bar ─────────────────── */
  .sticky-scroll-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    pointer-events: none;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .sticky-scroll-bar.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  :global(html[data-sticky-scroll="off"]) .sticky-scroll-bar {
    display: none;
  }

  /* crumbs are JS-injected — must use :global() so Astro scoping doesn't block them */
  :global(.sticky-scroll-crumbs) {
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 0;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18), 0 2px 6px rgba(0, 0, 0, 0.12);
    backdrop-filter: blur(6px);
  }

  :global([data-theme="dark"] .sticky-scroll-crumbs) {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6), 0 1px 6px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.04);
  }

  :global(.sticky-crumb) {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.18rem 1.1rem;
    font-family: var(--font-heading);
    color: var(--color-text-tertiary);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border-left: 2px solid transparent;
    transition: color 0.12s ease, background-color 0.12s ease;
    line-height: 1.5;
    border-bottom: 1px solid var(--color-border);
  }

  /* h2 — section root: prominent */
  :global(.sticky-crumb-h2) {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    padding-left: 1.1rem;
    letter-spacing: -0.01em;
  }

  /* h3 — subsection: medium */
  :global(.sticky-crumb-h3) {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-tertiary);
    padding-left: 2rem;
  }

  /* h4 — detail: quiet */
  :global(.sticky-crumb-h4) {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-tertiary);
    padding-left: 2.9rem;
    font-style: italic;
  }

  /* active (last) crumb gets accent colour + left bar */
  :global(.sticky-crumb:last-child) {
    border-bottom: none;
    color: var(--color-text);
    border-left-color: var(--color-link);
  }

  :global(.sticky-crumb-h2:last-child) { font-size: 0.84rem; font-weight: 700; }
  :global(.sticky-crumb-h3:last-child) { font-size: 0.77rem; font-weight: 600; }
  :global(.sticky-crumb-h4:last-child) { font-size: 0.72rem; font-weight: 500; font-style: normal; }

  :global(.sticky-crumb:hover) {
    color: var(--color-link);
    background-color: var(--color-surface);
  }

  :global(.sticky-crumb-arrow) {
    opacity: 0.35;
    flex-shrink: 0;
    font-size: 0.85em;
    position: relative;
    top: -1px;
  }

  /* Sticky toggle button — active state */
  :global(html[data-sticky-scroll="off"]) #float-sticky-toggle {
    opacity: 0.45;
  }

  /* ── Floating button panel ─────────────── */
  .floating-buttons {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 50;
    align-items: center;
  }

  /* Collapsible utility group */
  .float-more-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    transition: max-height 0.28s ease, opacity 0.22s ease;
  }

  .float-more-group.open {
    max-height: 16rem;
    opacity: 1;
    pointer-events: auto;
  }

  /* more toggle icons */
  #float-more-toggle .icon-more-close { display: none; }
  #float-more-toggle.open .icon-more-open { display: none; }
  #float-more-toggle.open .icon-more-close { display: block; }
  #float-more-toggle.open { border-color: var(--color-link); color: var(--color-link); }

  .float-btn {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-text-secondary);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .float-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-tertiary);
  }

  /* Width toggle icons (floating) */
  :global(html[data-wide="true"]) #float-width-toggle .icon-expand { display: none; }
  :global(html[data-wide="true"]) #float-width-toggle .icon-compress { display: block; }
  :global(html:not([data-wide])) #float-width-toggle .icon-compress { display: none; }
  :global(html:not([data-wide])) #float-width-toggle .icon-expand { display: block; }

  /* Theme toggle icons (floating) */
  :global([data-theme="dark"]) #float-theme-toggle .icon-moon { display: none; }
  :global([data-theme="dark"]) #float-theme-toggle .icon-sun { display: block; }
  :global([data-theme="light"]) #float-theme-toggle .icon-sun { display: none; }
  :global([data-theme="light"]) #float-theme-toggle .icon-moon { display: block; }

  /* Hide width toggle on small screens (wide mode has no effect there) */
  @media (max-width: 1150px) {
    #float-width-toggle {
      display: none;
    }
  }

  /* Scroll toggle icons — toggled by JS via .scrolled class */
  #scroll-toggle .icon-up { display: none; }
  #scroll-toggle .icon-down { display: block; }
  #scroll-toggle.scrolled .icon-up { display: block; }
  #scroll-toggle.scrolled .icon-down { display: none; }
</style>

<script>
  function applyWidth(wide: boolean) {
    if (wide) {
      document.documentElement.dataset.wide = "true";
      localStorage.setItem("wide", "true");
    } else {
      delete document.documentElement.dataset.wide;
      localStorage.removeItem("wide");
    }
  }

  // ── More toggle ─────────────────────────
  const moreToggleBtn = document.getElementById("float-more-toggle");
  const moreGroup = document.getElementById("float-more-group");

  moreToggleBtn?.addEventListener("click", () => {
    const open = moreGroup?.classList.toggle("open");
    moreToggleBtn.classList.toggle("open", open);
    moreToggleBtn.setAttribute("aria-label", open ? "Close options" : "More options");
    moreToggleBtn.setAttribute("title", open ? "Close options" : "More options");
  });

  // ── Floating width toggle ───────────────
  const floatWidthBtn = document.getElementById("float-width-toggle");
  floatWidthBtn?.addEventListener("click", () => {
    applyWidth(document.documentElement.dataset.wide !== "true");
  });

  // ── Floating theme toggle ───────────────
  const floatThemeBtn = document.getElementById("float-theme-toggle");

  function applyTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("theme", theme);
  }

  floatThemeBtn?.addEventListener("click", () => {
    const loader = document.getElementById("theme-loader");
    if (loader) loader.classList.add("active");

    requestAnimationFrame(() => {
      const current = document.documentElement.dataset.theme;
      applyTheme(current === "dark" ? "light" : "dark");
      setTimeout(() => loader?.classList.remove("active"), 350);
    });
  });

  // ── Scroll toggle (top ↔ bottom) ────────
  const scrollToggle = document.getElementById("scroll-toggle");

  function updateScrollBtn() {
    if (!scrollToggle) return;
    const atTop = window.scrollY < 100;
    scrollToggle.classList.toggle("scrolled", !atTop);
    scrollToggle.setAttribute("aria-label", atTop ? "Scroll to bottom" : "Scroll to top");
    scrollToggle.setAttribute("title", atTop ? "Scroll to bottom" : "Scroll to top");
  }

  window.addEventListener("scroll", updateScrollBtn, { passive: true });
  updateScrollBtn();

  scrollToggle?.addEventListener("click", () => {
    if (window.scrollY < 100) {
      window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" });
    } else {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });

  // ── VSCode-style Sticky Scroll ──────────
  const stickyBar = document.getElementById("sticky-scroll-bar");
  const stickyCrumbs = document.getElementById("sticky-scroll-crumbs");
  const stickyToggleBtn = document.getElementById("float-sticky-toggle");

  // Init sticky scroll state (default: ON)
  function isStickyScrollOn(): boolean {
    return document.documentElement.dataset.stickyScroll !== "off";
  }

  function applyStickyScroll(on: boolean) {
    if (on) {
      delete document.documentElement.dataset.stickyScroll;
      localStorage.removeItem("stickyScroll");
    } else {
      document.documentElement.dataset.stickyScroll = "off";
      localStorage.setItem("stickyScroll", "off");
    }
  }

  // Restore saved preference
  if (localStorage.getItem("stickyScroll") === "off") {
    applyStickyScroll(false);
  }

  stickyToggleBtn?.addEventListener("click", () => {
    applyStickyScroll(!isStickyScrollOn());
    updateStickyScroll();
  });

  // Collect headings from article prose (h2–h4)
  const headings: { el: HTMLElement; level: number; top: number }[] = [];

  function collectHeadings() {
    headings.length = 0;
    const prose = document.querySelector(".prose");
    if (!prose) return;
    const els = prose.querySelectorAll<HTMLElement>("h2, h3, h4");
    els.forEach((el) => {
      const level = parseInt(el.tagName[1], 10);
      headings.push({ el, level, top: 0 });
    });
  }

  function refreshHeadingTops() {
    headings.forEach((h) => {
      h.top = h.el.getBoundingClientRect().top + window.scrollY;
    });
  }

  // Build the sticky crumb stack from headings above viewport
  function updateStickyScroll() {
    if (!stickyBar || !stickyCrumbs) return;
    if (!isStickyScrollOn()) {
      stickyBar.classList.remove("visible");
      return;
    }

    const scrollTop = window.scrollY;

    // Find all headings whose top is above the current scroll position
    // (i.e., heading.top < scrollTop + a small buffer so the heading itself isn't shown while fully visible)
    const buffer = 10;
    const above = headings.filter((h) => h.top < scrollTop + buffer);

    if (above.length === 0) {
      stickyBar.classList.remove("visible");
      return;
    }

    // Build a hierarchy breadcrumb: track the last seen heading at each level
    const crumbMap = new Map<number, typeof above[0]>();
    let minLevel = 6;

    for (const h of above) {
      crumbMap.set(h.level, h);
      if (h.level < minLevel) minLevel = h.level;
      // When we go up a level, clear deeper levels
      for (const [lvl] of crumbMap) {
        if (lvl > h.level) crumbMap.delete(lvl);
      }
    }

    // Sort by level to display in order
    const crumbLevels = Array.from(crumbMap.keys()).sort((a, b) => a - b);

    // Render
    stickyCrumbs.innerHTML = "";
    const baseLevel = crumbLevels[0] ?? 2;

    crumbLevels.forEach((level) => {
      const h = crumbMap.get(level)!;
      const crumb = document.createElement("div");
      crumb.className = `sticky-crumb sticky-crumb-h${level}`;

      if (level > baseLevel) {
        const arrow = document.createElement("span");
        arrow.className = "sticky-crumb-arrow";
        arrow.textContent = "›";
        crumb.appendChild(arrow);
      }

      const text = document.createTextNode(h.el.textContent?.trim() ?? "");
      crumb.appendChild(text);

      crumb.addEventListener("click", () => {
        h.el.scrollIntoView({ behavior: "smooth", block: "start" });
      });

      stickyCrumbs.appendChild(crumb);
    });

    stickyBar.classList.add("visible");
  }

  // Init
  collectHeadings();
  refreshHeadingTops();
  updateStickyScroll();

  // Update tops on resize (layout shift)
  window.addEventListener("resize", () => {
    refreshHeadingTops();
    updateStickyScroll();
  }, { passive: true });

  window.addEventListener("scroll", () => {
    updateStickyScroll();
  }, { passive: true });
</script>
