---
import Heading from "./Heading.astro";
import Prose from "./Prose.astro";

interface Props {
  title: string;
  date: Date;
  description: string;
  readingTime?: string;
  postId?: string;
}

const { title, date, description, readingTime, postId } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="article">
  <header class="article-header">
    <Heading as="h1">{title}</Heading>
    <p class="article-meta">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon"
        ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line
          x1="16"
          y1="2"
          x2="16"
          y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line
          x1="3"
          y1="10"
          x2="21"
          y2="10"></line></svg
      >
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {
        readingTime && (
          <>
            <span class="separator"> — </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon"
            >
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            <span class="article-reading-time">{readingTime}</span>
          </>
        )
      }
    </p>
  </header>
  <Prose>
    <slot />
  </Prose>
  {postId && (
    <div class="article-hits">
      <img id="hits-badge" alt="Hits" data-post-id={postId} />
    </div>
  )}
  <script>
    const badge = document.getElementById('hits-badge');
    if (badge) {
      const id = badge.dataset.postId;
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const color = isDark ? '6ba3f5' : '3d6aa8';
      const label = isDark ? '333331' : '525d68';
      badge.src = `https://hits.sh/knhs.in/${id}.svg?style=plastic&color=${color}&labelColor=${label}`;
    }
  </script>
</article>

<div class="floating-buttons">
  <button id="float-width-toggle" class="float-btn" aria-label="Toggle reading width" title="Toggle reading width">
    <svg class="icon-expand" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="15 3 21 3 21 9"></polyline>
      <polyline points="9 21 3 21 3 15"></polyline>
      <line x1="21" y1="3" x2="14" y2="10"></line>
      <line x1="3" y1="21" x2="10" y2="14"></line>
    </svg>
    <svg class="icon-compress" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="4 14 10 14 10 20"></polyline>
      <polyline points="20 10 14 10 14 4"></polyline>
      <line x1="10" y1="14" x2="3" y2="21"></line>
      <line x1="21" y1="3" x2="14" y2="10"></line>
    </svg>
  </button>
  <button id="float-theme-toggle" class="float-btn" aria-label="Toggle theme" title="Toggle dark / light mode">
    <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
    <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>
  <button id="scroll-toggle" class="float-btn" aria-label="Scroll to bottom" title="Scroll to bottom">
    <svg class="icon-up" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="18 15 12 9 6 15"></polyline>
    </svg>
    <svg class="icon-down" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>
</div>

<style>
  .article {
    max-width: var(--width-content);
    transition: max-width 0.25s ease;
  }

  :global(html[data-wide="true"]) .article {
    max-width: var(--width-page);
  }

  .article-header {
    margin-bottom: var(--space-xl);
  }

  .article-meta {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-sm);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .icon {
    display: inline-block;
    vertical-align: middle;
    margin-right: -0.25rem;
    position: relative;
    top: -2px;
  }

  .separator {
    color: var(--color-text-tertiary);
    margin: 0 0.125rem;
  }

  .article-meta {
    justify-content: flex-start;
  }

  .article-hits {
    margin-top: var(--space-xl);
    display: flex;
    justify-content: center;
  }

  /* ── Floating button panel ─────────────── */
  .floating-buttons {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 50;
  }

  .float-btn {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-text-secondary);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .float-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-tertiary);
  }

  /* Width toggle icons (floating) */
  :global(html[data-wide="true"]) #float-width-toggle .icon-expand { display: none; }
  :global(html[data-wide="true"]) #float-width-toggle .icon-compress { display: block; }
  :global(html:not([data-wide])) #float-width-toggle .icon-compress { display: none; }
  :global(html:not([data-wide])) #float-width-toggle .icon-expand { display: block; }

  /* Theme toggle icons (floating) */
  :global([data-theme="dark"]) #float-theme-toggle .icon-moon { display: none; }
  :global([data-theme="dark"]) #float-theme-toggle .icon-sun { display: block; }
  :global([data-theme="light"]) #float-theme-toggle .icon-sun { display: none; }
  :global([data-theme="light"]) #float-theme-toggle .icon-moon { display: block; }

  /* Hide width toggle on small screens (wide mode has no effect there) */
  @media (max-width: 1150px) {
    #float-width-toggle {
      display: none;
    }
  }

  /* Scroll toggle icons — toggled by JS via .scrolled class */
  #scroll-toggle .icon-up { display: none; }
  #scroll-toggle .icon-down { display: block; }
  #scroll-toggle.scrolled .icon-up { display: block; }
  #scroll-toggle.scrolled .icon-down { display: none; }
</style>

<script>
  function applyWidth(wide: boolean) {
    if (wide) {
      document.documentElement.dataset.wide = "true";
      localStorage.setItem("wide", "true");
    } else {
      delete document.documentElement.dataset.wide;
      localStorage.removeItem("wide");
    }
  }

  // ── Floating width toggle ───────────────
  const floatWidthBtn = document.getElementById("float-width-toggle");
  floatWidthBtn?.addEventListener("click", () => {
    applyWidth(document.documentElement.dataset.wide !== "true");
  });

  // ── Floating theme toggle ───────────────
  const floatThemeBtn = document.getElementById("float-theme-toggle");

  function applyTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("theme", theme);
  }

  floatThemeBtn?.addEventListener("click", () => {
    const loader = document.getElementById("theme-loader");
    if (loader) loader.classList.add("active");

    requestAnimationFrame(() => {
      const current = document.documentElement.dataset.theme;
      applyTheme(current === "dark" ? "light" : "dark");
      setTimeout(() => loader?.classList.remove("active"), 350);
    });
  });

  // ── Scroll toggle (top ↔ bottom) ────────
  const scrollToggle = document.getElementById("scroll-toggle");

  function updateScrollBtn() {
    if (!scrollToggle) return;
    const atTop = window.scrollY < 100;
    scrollToggle.classList.toggle("scrolled", !atTop);
    scrollToggle.setAttribute("aria-label", atTop ? "Scroll to bottom" : "Scroll to top");
    scrollToggle.setAttribute("title", atTop ? "Scroll to bottom" : "Scroll to top");
  }

  window.addEventListener("scroll", updateScrollBtn, { passive: true });
  updateScrollBtn();

  scrollToggle?.addEventListener("click", () => {
    if (window.scrollY < 100) {
      window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" });
    } else {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });
</script>
