---
const year = new Date().getFullYear();
---

<footer class="footer" aria-label="Site footer">
  <nav class="footer-nav" aria-label="Footer navigation">
    <a href="/photo-gallery">Photo Gallery</a>
    <span class="footer-dot" aria-hidden="true">&middot;</span>
    <a href="/photo-albums"s>Photo Albums</a>
    <span class="footer-dot" aria-hidden="true">&middot;</span>
    <a href="/tags">Tags</a>
    <span class="footer-dot" aria-hidden="true">&middot;</span>
    <a href="/rss.xml" aria-label="RSS Feed">RSS</a>
    <span class="footer-dot" aria-hidden="true">&middot;</span>
    <a href="/sitemap-index.xml" aria-label="Sitemap">Sitemap</a>
    <span class="footer-dot" aria-hidden="true">&middot;</span>
    <a href="https://github.com/a1kundu" target="_blank" rel="noopener noreferrer">GitHub<span class="sr-only"> (opens in a new tab)</span></a>
    <span class="footer-dot" aria-hidden="true">&middot;</span>
    <a href="https://linkedin.com/in/a1kundu" target="_blank" rel="noopener noreferrer">LinkedIn<span class="sr-only"> (opens in a new tab)</span></a>
  </nav>
  <p>&copy; {year} ArijitK.in</p>
</footer>

<style>
  .footer {
    margin-top: var(--space-2xl);
    padding: var(--space-xl) 0 var(--space-lg);
    position: relative;
  }

  .footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border) 15%,
      var(--color-border) 85%,
      transparent
    );
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .footer-dot {
    color: var(--color-border);
    font-size: 0.875rem;
    user-select: none;
  }

  .footer-nav a {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .footer-nav a:hover {
    color: var(--color-link);
  }

  .footer p {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    color: var(--color-text-tertiary);
    text-align: center;
    letter-spacing: 0.03em;
    /* text-transform: uppercase; */
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
