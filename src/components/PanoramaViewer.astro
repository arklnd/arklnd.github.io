---
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<div class="pano-wrap" id="pano-wrap" aria-label={alt} role="img" data-src={src}>
  <canvas id="pano-canvas"></canvas>
  <div class="pano-loader" id="pano-loader">
    <div class="pano-spinner"></div>
  </div>
  <div class="pano-hint" id="pano-hint" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20A14.5 14.5 0 0 0 12 2"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
    <span>Drag to explore · Scroll to zoom</span>
  </div>
  <button class="pano-motion" id="pano-motion" type="button" aria-pressed="false" hidden>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/><path d="M8 6h8"/></svg>
    <span>Motion</span>
  </button>
  <div class="pano-badge" aria-hidden="true">360°</div>
</div>

<script>
  import {
    WebGLRenderer,
    Scene,
    PerspectiveCamera,
    SphereGeometry,
    CylinderGeometry,
    MeshBasicMaterial,
    Mesh,
    Euler,
    Quaternion,
    Vector3,
    TextureLoader,
    SRGBColorSpace,
    LinearFilter,
    BackSide,
    RepeatWrapping,
  } from "three";

  function setupPanoramaViewer() {
    const wrap = document.getElementById("pano-wrap") as HTMLElement | null;
    const canvas = document.getElementById("pano-canvas");
    const loader = document.getElementById("pano-loader") as HTMLElement | null;
    const hint = document.getElementById("pano-hint") as HTMLElement | null;
    const motionButton = document.getElementById("pano-motion") as HTMLButtonElement | null;

    if (!wrap || !canvas || !loader) return;
    const src = wrap.dataset.src!;
    // Re-bind as definitely non-null so nested functions don't lose the narrowing
    const el = wrap;
    if (el.dataset.panoInitialized === "true") return;
    el.dataset.panoInitialized = "true";

    {
      // ── Renderer ──
      const renderer = new WebGLRenderer({ canvas, antialias: false, alpha: false });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      // ── Scene / Camera ──
      const scene = new Scene();
      const camera = new PerspectiveCamera(90, 1, 0.1, 1000); // fov, aspect, near, far
      camera.rotation.order = "YXZ";

      const material = new MeshBasicMaterial({ map: null, side: BackSide });

      // ── Load texture, then build geometry based on aspect ratio ──
      const texLoader = new TextureLoader();
      texLoader.load(
        src,
        (tex) => {
          tex.colorSpace = SRGBColorSpace;
          tex.generateMipmaps = false;
          tex.minFilter = LinearFilter;
          tex.wrapS = RepeatWrapping;
          tex.repeat.x = -1; // flip horizontally to correct BackSide mirror
          material.map = tex;
          material.needsUpdate = true;

          const imgW = tex.image.width;
          const imgH = tex.image.height;
          const ratio = imgW / imgH;

          let mesh: Mesh;
          if (ratio > 3) {
            // Cylindrical strip panorama (e.g. 9:1, 4:1)
            // Assume 360° horizontal; compute cylinder height from aspect ratio
            const radius = 500;
            const height = 2 * Math.PI * radius * (imgH / imgW);
            const geometry = new CylinderGeometry(radius, radius, height, 64, 1, true);
            mesh = new Mesh(geometry, material);
          } else {
            // Equirectangular — full (2:1) or partial photosphere (2.x:1)
            // Compute vertical angular coverage from aspect ratio
            const fullHeight = imgW / 2; // height that would cover full 180°
            const thetaLength = Math.min(Math.PI, (imgH / fullHeight) * Math.PI);
            const thetaStart = (Math.PI - thetaLength) / 2; // assume centered crop
            const geometry = new SphereGeometry(500, 60, 40, 0, Math.PI * 2, thetaStart, thetaLength);
            mesh = new Mesh(geometry, material);
          }
          scene.add(mesh);

          // Clamp vertical look range based on geometry coverage
          if (ratio > 3) {
            const vertAngleDeg = (imgH / imgW) * 360;
            LAT_MAX = Math.min(85, vertAngleDeg / 2 - 5);
            // Set FOV to fit the strip snugly
            fov = Math.min(FOV_MAX, Math.max(FOV_MIN, vertAngleDeg * 0.9));
            camera.fov = fov;
            camera.updateProjectionMatrix();
          }

          loader.style.display = "none";
          needsRender = true;
          resize();
          animate();
          // Fade hint out after a few seconds
          setTimeout(() => {
            if (hint) hint.style.opacity = "0";
          }, 3500);
        },
        undefined,
        (err) => {
          console.error("PanoramaViewer: texture load error", err);
          loader.style.display = "none";
        }
      );

      // ── View state ──
      let lon = 0;   // horizontal angle (degrees)
      let lat = 0;   // vertical angle (degrees)
      let fov = 90;
      let LAT_MAX = 85;
      const FOV_MIN = 30;
      const FOV_MAX = 110;
      let needsRender = false; // render-on-demand flag
      let manualViewDirty = false;
      let paused = false; // tab visibility pause
      let destroyed = false;
      const DEG2RAD = Math.PI / 180;

      // ── Mouse drag ──
      let isPointerDown = false;
      let isPinching = false; // suppress drag during pinch zoom
      let pointerX = 0;
      let pointerY = 0;
      let didDrag = false;
      let didPinch = false;
      let velocityX = 0;  // momentum horizontal (deg/frame)
      let velocityY = 0;  // momentum vertical (deg/frame)
      const DRAG_SENSITIVITY = 0.105;
      const FRICTION = 0.924;  // decay per frame (0 = instant stop, 1 = no friction)
      const MIN_VELOCITY = 0.01;

      // ── Device motion look ──
      type DeviceOrientationEventWithPermission = typeof DeviceOrientationEvent & {
        requestPermission?: () => Promise<"granted" | "denied" | "default">;
      };

      let motionEnabled = false;
      let hasMotionTarget = false;
      let motionHeadingOffset = 0;
      const MOTION_SMOOTHING = 0.18;
      const motionEuler = new Euler(0, 0, 0, "YXZ");
      const motionTargetQuaternion = new Quaternion();
      const motionDeviceQuaternion = new Quaternion();
      const motionHeadingQuaternion = new Quaternion();
      const motionScreenQuaternion = new Quaternion();
      const motionYAxis = new Vector3(0, 1, 0);
      const motionZAxis = new Vector3(0, 0, 1);
      const motionCameraAdjustment = new Quaternion(-Math.sqrt(0.5), 0, 0, Math.sqrt(0.5));

      function screenAngle() {
        if (typeof screen.orientation?.angle === "number") return screen.orientation.angle;
        const legacyWindow = window as Window & { orientation?: number };
        return typeof legacyWindow.orientation === "number" ? legacyWindow.orientation : 0;
      }

      function setQuaternionFromDeviceOrientation(target: Quaternion, e: DeviceOrientationEvent) {
        const alpha = (e.alpha ?? 0) * DEG2RAD;
        const beta = (e.beta ?? 0) * DEG2RAD;
        const gamma = (e.gamma ?? 0) * DEG2RAD;
        const orient = screenAngle() * DEG2RAD;

        motionEuler.set(beta, alpha, -gamma, "YXZ");
        target.setFromEuler(motionEuler);
        target.multiply(motionCameraAdjustment);
        target.multiply(motionScreenQuaternion.setFromAxisAngle(motionZAxis, -orient));
      }

      function syncLonLatFromCamera() {
        motionEuler.setFromQuaternion(camera.quaternion, "YXZ");
        lon = -motionEuler.y / DEG2RAD;
        lat = Math.max(-LAT_MAX, Math.min(LAT_MAX, motionEuler.x / DEG2RAD));
      }

      function resetMotionOrigin() {
        hasMotionTarget = false;
        motionHeadingOffset = 0;
        velocityX = 0;
        velocityY = 0;
      }

      function setMotionButtonState() {
        if (!motionButton) return;
        motionButton.classList.toggle("is-active", motionEnabled);
        motionButton.setAttribute("aria-pressed", motionEnabled ? "true" : "false");
      }

      function onDeviceOrientation(e: DeviceOrientationEvent) {
        if (!motionEnabled || e.alpha === null || e.beta === null || e.gamma === null) return;

        setQuaternionFromDeviceOrientation(motionDeviceQuaternion, e);
        motionEuler.setFromQuaternion(motionDeviceQuaternion, "YXZ");
        const deviceLon = -motionEuler.y / DEG2RAD;

        if (!hasMotionTarget) {
          syncLonLatFromCamera();
          motionHeadingOffset = lon - deviceLon;
        }

        motionHeadingQuaternion.setFromAxisAngle(motionYAxis, -motionHeadingOffset * DEG2RAD);
        motionTargetQuaternion.copy(motionHeadingQuaternion).multiply(motionDeviceQuaternion);
        hasMotionTarget = true;
        needsRender = true;
      }

      const onMotionButtonClick = async () => {
        if (!motionButton) return;

        if (motionEnabled) {
          motionEnabled = false;
          window.removeEventListener("deviceorientation", onDeviceOrientation, true);
          resetMotionOrigin();
          setMotionButtonState();
          return;
        }

        const MotionEvent = window.DeviceOrientationEvent as DeviceOrientationEventWithPermission | undefined;
        if (MotionEvent?.requestPermission) {
          const permission = await MotionEvent.requestPermission();
          if (permission !== "granted") return;
        }

        motionEnabled = true;
        resetMotionOrigin();
        window.addEventListener("deviceorientation", onDeviceOrientation, true);
        setMotionButtonState();
      };

      if (motionButton && "DeviceOrientationEvent" in window && window.matchMedia("(pointer: coarse)").matches) {
        motionButton.hidden = false;
        motionButton.addEventListener("click", onMotionButtonClick);
      }

      el.addEventListener("pointerdown", (e) => {
        if (!isPointerDown) {
          didDrag = false;
          didPinch = false;
        }
        isPointerDown = true;
        pointerX = e.clientX;
        pointerY = e.clientY;
        velocityX = 0;
        velocityY = 0;
        el.setPointerCapture(e.pointerId);
        el.style.cursor = "grabbing";
      });

      el.addEventListener("pointermove", (e) => {
        if (!isPointerDown || isPinching) return;
        const fovScale = fov / 90; // finer control when zoomed in
        const dx = (e.clientX - pointerX) * DRAG_SENSITIVITY * fovScale;
        const dy = (e.clientY - pointerY) * DRAG_SENSITIVITY * fovScale;
        velocityX = -dx;
        velocityY = dy;
        didDrag = true;
        lon += velocityX;
        lat += velocityY;
        lat = Math.max(-LAT_MAX, Math.min(LAT_MAX, lat));
        pointerX = e.clientX;
        pointerY = e.clientY;
        manualViewDirty = true;
        needsRender = true;
      });

      el.addEventListener("pointerup", () => {
        isPointerDown = false;
        if (motionEnabled && didDrag && !didPinch) resetMotionOrigin();
        el.style.cursor = "grab";
      });

      el.addEventListener("pointercancel", () => {
        isPointerDown = false;
        velocityX = 0;
        velocityY = 0;
        el.style.cursor = "grab";
      });

      // ── Scroll / wheel zoom ──
      el.addEventListener("wheel", (e) => {
        e.preventDefault();
        fov += e.deltaY * 0.05;
        fov = Math.max(FOV_MIN, Math.min(FOV_MAX, fov));
        camera.fov = fov;
        camera.updateProjectionMatrix();
        needsRender = true;
      }, { passive: false });

      // ── Touch pinch zoom ──
      let lastPinchDist = 0;

      el.addEventListener("touchstart", (e) => {
        if (e.touches.length === 2) {
          isPinching = true;
          didPinch = true;
          velocityX = 0;
          velocityY = 0;
          lastPinchDist = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
          );
        }
      }, { passive: true });

      el.addEventListener("touchend", (e) => {
        if (e.touches.length < 2 && isPinching) {
          isPinching = false;
          // Re-sync pointer to remaining finger to prevent jump
          if (e.touches.length === 1) {
            pointerX = e.touches[0].clientX;
            pointerY = e.touches[0].clientY;
          }
        }
      }, { passive: true });

      // ── Double-tap to reset zoom ──
      let lastTapTime = 0;
      el.addEventListener("touchend", (e) => {
        if (e.touches.length !== 0 || isPinching) return;
        const now = Date.now();
        if (now - lastTapTime < 300) {
          // Double tap detected — reset FOV
          fov = 90;
          camera.fov = fov;
          camera.updateProjectionMatrix();
          needsRender = true;
          lastTapTime = 0;
        } else {
          lastTapTime = now;
        }
      }, { passive: true });

      el.addEventListener("touchmove", (e) => {
        if (e.touches.length === 2) {
          const dist = Math.hypot(
            e.touches[0].clientX - e.touches[1].clientX,
            e.touches[0].clientY - e.touches[1].clientY
          );
          const delta = lastPinchDist - dist;
          fov += delta * 0.1;
          fov = Math.max(FOV_MIN, Math.min(FOV_MAX, fov));
          camera.fov = fov;
          camera.updateProjectionMatrix();
          lastPinchDist = dist;
          needsRender = true;
          e.preventDefault();
        }
      }, { passive: false });

      // ── Keyboard look ──
      const KEYS: Record<string, boolean> = {};
      const onKeyDown = (e: KeyboardEvent) => { KEYS[e.key] = true; needsRender = true; };
      const onKeyUp = (e: KeyboardEvent) => { KEYS[e.key] = false; };
      window.addEventListener("keydown", onKeyDown);
      window.addEventListener("keyup", onKeyUp);

      // ── Resize ──
      function resize() {
        const w = el.clientWidth;
        const h = el.clientHeight;
        renderer.setSize(w, h);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
        needsRender = true;
      }
      const ro = new ResizeObserver(resize);
      ro.observe(el);

      // ── Pause when tab hidden ──
      const onVisChange = () => { paused = document.hidden; if (!paused) needsRender = true; };
      document.addEventListener("visibilitychange", onVisChange);

      // ── Cleanup on Astro page swap (View Transitions) ──
      const cleanup = () => {
        destroyed = true;
        ro.disconnect();
        window.removeEventListener("keydown", onKeyDown);
        window.removeEventListener("keyup", onKeyUp);
        document.removeEventListener("visibilitychange", onVisChange);
        motionButton?.removeEventListener("click", onMotionButtonClick);
        window.removeEventListener("deviceorientation", onDeviceOrientation, true);
        scene.traverse((obj) => {
          if (obj instanceof Mesh) {
            obj.geometry.dispose();
            if (obj.material.map) obj.material.map.dispose();
            obj.material.dispose();
          }
        });
        renderer.dispose();
      };
      document.addEventListener("astro:before-swap", cleanup, { once: true });

      // ── Animation loop ──
      function animate() {
        if (destroyed) return;
        requestAnimationFrame(animate);
        if (paused) return;

        let moved = false;

        // Momentum — apply velocity when not dragging
        if (!isPointerDown) {
          if (Math.abs(velocityX) > MIN_VELOCITY || Math.abs(velocityY) > MIN_VELOCITY) {
            lon += velocityX;
            lat += velocityY;
            lat = Math.max(-LAT_MAX, Math.min(LAT_MAX, lat));
            velocityX *= FRICTION;
            velocityY *= FRICTION;
            manualViewDirty = true;
            moved = true;
          }
        }

        if (motionEnabled && !isPointerDown && !isPinching && hasMotionTarget) {
          if (1 - Math.abs(camera.quaternion.dot(motionTargetQuaternion)) > 0.000001) {
            camera.quaternion.slerp(motionTargetQuaternion, MOTION_SMOOTHING);
            syncLonLatFromCamera();
            moved = true;
          }
        }

        // Keyboard look
        if (KEYS["ArrowLeft"]  || KEYS["a"] || KEYS["A"]) { lon -= 0.35; manualViewDirty = true; moved = true; }
        if (KEYS["ArrowRight"] || KEYS["d"] || KEYS["D"]) { lon += 0.35; manualViewDirty = true; moved = true; }
        if (KEYS["ArrowUp"]    || KEYS["w"] || KEYS["W"]) { lat = Math.min(LAT_MAX, lat + 0.35); manualViewDirty = true; moved = true; }
        if (KEYS["ArrowDown"]  || KEYS["s"] || KEYS["S"]) { lat = Math.max(-LAT_MAX, lat - 0.35); manualViewDirty = true; moved = true; }
        if (KEYS["+"] || KEYS["="]) { fov = Math.max(FOV_MIN, fov - 0.5); camera.fov = fov; camera.updateProjectionMatrix(); moved = true; }
        if (KEYS["-"])              { fov = Math.min(FOV_MAX, fov + 0.5); camera.fov = fov; camera.updateProjectionMatrix(); moved = true; }

        // Only render when something changed
        if (moved || needsRender) {
          if (manualViewDirty) {
            camera.rotation.set(lat * DEG2RAD, -lon * DEG2RAD, 0, "YXZ");
            manualViewDirty = false;
          }
          renderer.render(scene, camera);
          needsRender = false;
        }
      }
    }
  }

  document.addEventListener("astro:page-load", setupPanoramaViewer);
  setupPanoramaViewer();
</script>

<style>
  .pano-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
    cursor: grab;
    user-select: none;
    touch-action: none;
    background: #0d0d0d;
  }

  #pano-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .pano-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    background: #0d0d0d;
    pointer-events: none;
  }

  .pano-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255,255,255,0.15);
    border-top-color: var(--color-link, #7fd4e1);
    border-radius: 50%;
    animation: pano-spin 0.75s linear infinite;
  }

  @keyframes pano-spin {
    to { transform: rotate(360deg); }
  }

  .pano-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 5;
    padding: 0.2rem 0.55rem;
    font-family: var(--font-heading, system-ui);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #fff;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    pointer-events: none;
  }

  .pano-motion {
    position: absolute;
    top: 0.75rem;
    right: 4.2rem;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 1.75rem;
    padding: 0.25rem 0.55rem;
    font-family: var(--font-heading, system-ui);
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
  }

  .pano-motion[hidden] {
    display: none;
  }

  .pano-motion.is-active {
    color: #06191c;
    background: var(--color-link, #7fd4e1);
    border-color: transparent;
  }

  .pano-motion svg {
    flex: 0 0 auto;
  }

  .pano-hint {
    position: absolute;
    bottom: 6rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.85rem;
    font-family: var(--font-heading, system-ui);
    font-size: 0.78rem;
    color: rgba(255,255,255,0.9);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 20px;
    pointer-events: none;
    transition: opacity 0.8s ease;
    white-space: nowrap;
  }
</style>
