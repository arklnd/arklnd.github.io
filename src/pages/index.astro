---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import PostCard from "../components/PostCard.astro";
import TagPill from "../components/TagPill.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => import.meta.env.DEV || !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Top tags by post count (for "Browse by Topic" section)
const tagMap = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags.forEach((tag: string) => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});
const topTags = Array.from(tagMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);
---

<Layout description="A personal blog about technology, systems, tools, ideas, photography and thought sharing.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Arijit's Blog",
    "description": "A personal blog about technology, systems, tools, ideas, photography and thought sharing.",
    "url": Astro.site?.href,
    "inLanguage": "en",
    "author": {
      "@type": "Person",
      "name": "Arijit Kundu",
      "url": Astro.site?.href,
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${Astro.site?.href}search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  })} />
  <section class="home">
    <header class="home-header">
      <div class="home-header-top-rule"></div>
      <div class="home-header-masthead">
        <Heading as="h1">Arijit's Blog</Heading>
      </div>
      <div class="home-header-meta">
        <span class="home-tagline">A personal blog about technology, systems, tools, ideas, photography and thought sharing.</span>
        <time class="home-dateline" datetime={new Date().toISOString().slice(0,10)}>{new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </div>
      <div class="home-header-bottom-rule"></div>
    </header>
    <ul class="post-grid" role="list">
      {posts.map((post) => (
        <PostCard
          slug={post.id}
          variant="grid"
          reactions={true}
          transition={true}
        />
      ))}
    </ul>

    <section class="home-tags" aria-label="Browse by topic">
      <div class="home-tags-header">
        <h2 class="home-tags-title">Browse by Topic</h2>
        <a href={`${import.meta.env.BASE_URL}tags`} class="home-tags-all">All tags &gt;</a>
      </div>
      <div class="home-tags-cloud">
        {topTags.map((tag) => (
          <TagPill tag={tag} />
        ))}
      </div>
    </section>
  </section>
</Layout>

<style>
  .home-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: 0;
    border-bottom: none;
  }

  .home-header-top-rule {
    border-top: 3px solid var(--color-text);
    border-bottom: 1px solid var(--color-text);
    height: 5px;
    margin-bottom: var(--space-sm);
  }

  .home-header-masthead {
    text-align: center;
    padding: var(--space-sm) 0;
  }

  .home-header :global(.heading-h1) {
    font-family: var(--font-body);
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-align: center;
    line-height: 1.05;
  }

  .home-header-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    border-top: 1px solid var(--color-text);
    border-bottom: 1px solid var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .home-header-bottom-rule {
    display: none;
  }

  .home-tagline {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-style: italic;
    color: var(--color-text-secondary, var(--color-text));
    letter-spacing: 0.01em;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .home-dateline {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    color: var(--color-text-tertiary);
    white-space: nowrap;
    letter-spacing: 0.06em;
  }

  .post-grid {
    list-style: none;
    padding: 0;
    columns: 3 300px;
    column-gap: calc(var(--space-lg) * 1.5);
    column-rule: 1px solid var(--color-text);
  }

  @media (max-width: 640px) {
    .post-grid {
      columns: 1;
    }

    .home-tagline {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      min-width: 0;
    }
  }

  /* ── Browse by Topic ──────────────── */
  .home-tags {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: none;
    position: relative;
  }

  .home-tags::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border) 15%,
      var(--color-border) 85%,
      transparent
    );
  }

  .home-tags-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
  }

  .home-tags-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .home-tags-all {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .home-tags-all:hover {
    color: var(--color-link);
  }

  .home-tags-cloud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
</style>
