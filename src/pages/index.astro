---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import PostCard from "../components/PostCard.astro";
import TagPill from "../components/TagPill.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Top tags by post count (for "Browse by Topic" section)
const tagMap = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags.forEach((tag: string) => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});
const topTags = Array.from(tagMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);
---

<Layout title="Arijit's Blog" description="Arijit Kundu's tech blog — articles on software engineering, system design, authentication, Git workflows, .NET, reverse engineering, and developer tools.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Arijit's Blog",
    "description": "A tech blog by Arijit Kundu about software engineering, system design, and developer tools.",
    "url": Astro.site?.href,
    "inLanguage": "en",
    "author": {
      "@type": "Person",
      "name": "Arijit Kundu",
      "url": Astro.site?.href,
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${Astro.site?.href}search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  })} />
  <section class="home">
    <header class="home-header">
      <Heading as="h1">Arijit's Blog</Heading>
      <p class="home-tagline">A tech blog about systems, tools, and ideas.</p>
    </header>
    <ul class="post-grid" role="list">
      {posts.map((post) => (
        <PostCard
          slug={post.id}
          variant="grid"
          reactions={true}
          transition={true}
        />
      ))}
    </ul>

    <section class="home-tags" aria-label="Browse by topic">
      <div class="home-tags-header">
        <h2 class="home-tags-title">Browse by Topic</h2>
        <a href="/tags" class="home-tags-all">All tags &rarr;</a>
      </div>
      <div class="home-tags-cloud">
        {topTags.map((tag) => (
          <TagPill tag={tag} />
        ))}
      </div>
    </section>
  </section>
</Layout>

<style>
  .home-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: none;
    position: relative;
  }

  .home-header::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border) 15%,
      var(--color-border) 85%,
      transparent
    );
  }

  .home-header :global(.heading-h1) {
    background: linear-gradient(to right, var(--color-text) 0%, var(--color-link) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: 2.25rem;
    letter-spacing: -0.03em;
  }

  .home-tagline {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-sm);
    letter-spacing: 0.01em;
  }

  .post-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 640px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Browse by Topic ──────────────── */
  .home-tags {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: none;
    position: relative;
  }

  .home-tags::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border) 15%,
      var(--color-border) 85%,
      transparent
    );
  }

  .home-tags-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
  }

  .home-tags-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .home-tags-all {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .home-tags-all:hover {
    color: var(--color-link);
  }

  .home-tags-cloud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
</style>
