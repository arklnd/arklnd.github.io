---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Arijit's Blog" description="Arijit Kundu's tech blog — articles on software engineering, system design, authentication, Git workflows, .NET, reverse engineering, and developer tools.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Arijit's Blog",
    "description": "A tech blog by Arijit Kundu about software engineering, system design, and developer tools.",
    "url": Astro.site?.href,
    "inLanguage": "en",
    "author": {
      "@type": "Person",
      "name": "Arijit Kundu",
      "url": Astro.site?.href,
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${Astro.site?.href}search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  })} />
  <section class="home">
    <header class="home-header">
      <Heading as="h1">Arijit's Blog</Heading>
      <p class="home-tagline">A tech blog about systems, tools, and ideas.</p>
    </header>
    <ul class="post-grid" role="list">
      {posts.map((post) => (
        <PostCard
          slug={post.id}
          variant="grid"
          reactions={true}
          transition={true}
        />
      ))}
    </ul>
  </section>
</Layout>

<style>
  .home-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .home-tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
  }

  .post-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 640px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
