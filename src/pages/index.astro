---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Kintsugi-Life">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Kintsugi-Life",
    "description": "Unspoken words",
    "url": Astro.site?.href,
  })} />
  <section class="home">
    <header class="home-header">
      <Heading as="h1">Kintsugi-Life</Heading>
      <p class="home-tagline">Unspoken words</p>
    </header>
    <ul class="post-list">
      {
        posts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
            timeZone: "UTC",
          });
          const formattedTime = post.data.date.toLocaleTimeString("en-US", {
            hour: "numeric",
            minute: "2-digit",
            hour12: true,
            timeZone: "UTC",
          });
          return (
            <li class="post-item">
              <a href={`/posts/${post.id}`}>
                <span class="post-title">{post.data.title}</span>
                <span class="post-description">{post.data.description}</span>
                <time datetime={post.data.date.toISOString()}>{formattedDate} at {formattedTime}</time>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</Layout>

<style>
  .home-header {
    margin-bottom: var(--space-2xl);
  }

  .home-tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin-top: var(--space-sm);
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-gold);
    opacity: 0;
    transform: scaleY(0.4);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .post-item:hover::before {
    opacity: 0.7;
    transform: scaleY(1);
  }

  .post-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    transition: padding-left 0.2s ease;
  }

  .post-item:hover a {
    padding-left: var(--space-lg);
  }

  .post-item a:hover .post-title {
    color: var(--color-gold);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .post-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
  }
</style>
