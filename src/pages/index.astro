---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Arijit's Blog">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Arijit's Blog",
    "description": "A tech blog.",
    "url": Astro.site?.href,
  })} />
  <section class="home">
    <header class="home-header">
      <div class="home-header-overlay"></div>
      <div class="home-header-content">
        <Heading as="h1">Arijit's Blog</Heading>
        <p class="home-tagline">A tech blog about systems, tools, and ideas.</p>
      </div>
    </header>
    <ul class="post-grid" role="list">
      {
        posts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <li class="post-card">
              <a href={`/posts/${post.id}`} aria-label={post.data.title}>
                <div class="card-body">
                  <span class="post-title" transition:name={`post-title-${post.id}`}>{post.data.title}</span>
                  <span class="post-description">{post.data.description}</span>
                </div>
                <div class="card-footer">
                  <time datetime={post.data.date.toISOString()} transition:name={`post-date-${post.id}`}>{formattedDate}</time>
                  <span class="card-arrow" aria-hidden="true">→</span>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</Layout>

<style>
  .home-header {
    position: relative;
    margin-bottom: var(--space-2xl);
    padding: var(--space-2xl) var(--space-xl);
    border-radius: 14px;
    overflow: hidden;
    background: url("/PXL_20260419_171757455.jpg") center / cover no-repeat;
    min-height: 260px;
    display: flex;
    align-items: flex-end;
  }

  .home-header-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.34) 0%,
      rgba(0, 0, 0, 0.15) 50%,
      rgba(0, 0, 0, 0.05) 100%
    );
  }

  .home-header-content {
    position: relative;
    z-index: 1;
  }

  .home-header-content :global(h1) {
    color: #fff;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }

  .home-tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    margin-top: var(--space-sm);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  .post-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 640px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .post-card:hover {
    border-color: var(--color-link);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  [data-theme="dark"] .post-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .post-card a {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-lg);
    text-decoration: none;
    color: var(--color-text);
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .post-card:hover .post-title {
    color: var(--color-link);
  }

  .post-description {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .card-footer time {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.01em;
  }

  .card-arrow {
    font-size: 1rem;
    color: var(--color-text-tertiary);
    transition: color 0.15s ease, transform 0.15s ease;
    display: inline-block;
  }

  .post-card:hover .card-arrow {
    color: var(--color-link);
    transform: translateX(3px);
  }
</style>
