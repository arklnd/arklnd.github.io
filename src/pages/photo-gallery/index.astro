---
import Layout from "../../components/Layout.astro";
import ReactionsBadge from "../../components/ReactionsBadge.astro";
import photos from "../../data/gallery";

const isDev = import.meta.env.DEV;
---

<Layout title="Photo Gallery" description="Photo Gallery">
  <article class="gallery-page">
    <h1 class="gallery-title">Photo Gallery</h1>

    {photos.length === 0 && (
      <p class="gallery-empty">No photos yet. Add entries to <code>src/data/gallery.ts</code> and images to <code>public/images/gallery</code>.</p>
    )}

    <div class="gallery-grid">
      {photos.map((photo) => (
        <figure class="gallery-item">
          <div class="gallery-img-wrap">
            <a href={`/photo-gallery/${photo.slug}`}>
              <div class="img-loader"></div>
              <img
                src={isDev ? `/images/gallery/${photo.filename}` : `/images/gallery/thumbs/${photo.filename}.webp`}
                alt={photo.caption}
                loading="lazy"
                decoding="async"
                onload="this.previousElementSibling.style.display='none';this.classList.add('loaded')"
              />
            </a>
            <div class="gallery-reactions">
              <ReactionsBadge slug={`photo:${photo.slug}`} />
            </div>
            {(photo.caption || photo.place) && (
              <div class="gallery-overlay">
                <figcaption class="gallery-caption">
                  {photo.place && <span class="caption-place">{photo.place}</span>}
                  <span class="caption-text">{photo.caption}</span>
                </figcaption>
              </div>
            )}
          </div>
        </figure>
      ))}
    </div>
  </article>
</Layout>

<style>
  .gallery-page {
    padding: var(--space-xl) 0;
  }

  .gallery-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--space-xl);
    color: var(--color-text);
  }

  .gallery-empty {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  .gallery-empty code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: var(--color-code-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .gallery-grid {
    columns: 4 250px;
    column-gap: var(--space-md);
  }

  .gallery-item {
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    break-inside: avoid;
    margin-bottom: var(--space-md);
  }

  .gallery-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .gallery-img-wrap {
    position: relative;
    line-height: 0;
  }

  .gallery-img-wrap a {
    display: block;
  }

  .img-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    z-index: 1;
  }

  .img-loader::after {
    content: "";
    width: 28px;
    height: 28px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-link);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s ease;
    opacity: 0;
  }

  .gallery-item img.loaded {
    opacity: 1;
  }

  .gallery-item:hover img {
    opacity: 0.92;
  }

  .gallery-caption {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.3;
  }

  .caption-text {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #fff;
  }

  .caption-place {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 10px 10px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    pointer-events: none;
  }

  .gallery-reactions {
    position: absolute;
    top: 6px;
    right: 6px;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .gallery-grid {
      columns: 2 150px;
      column-gap: var(--space-sm);
    }

    .gallery-item {
      margin-bottom: var(--space-sm);
    }
  }
</style>
