---
import Layout from "../../components/Layout.astro";
import photos from "../../data/gallery";

const isDev = import.meta.env.DEV;
---

<Layout title="Photo Gallery" description="Photo Gallery">
  <article class="gallery-page">
    <h1 class="gallery-title">Photo Gallery</h1>

    {photos.length === 0 && (
      <p class="gallery-empty">No photos yet. Add entries to <code>src/data/gallery.ts</code> and images to <code>public/images/gallery</code>.</p>
    )}

    <div class="gallery-grid">
      {photos.map((photo) => (
        <figure class="gallery-item">
          <a href={`/photo-gallery/${photo.slug}`}>
            <img
              src={isDev ? `/images/gallery/${photo.filename}` : `/images/gallery/thumbs/${photo.filename.replace(/\.\w+$/, '.webp')}`}
              alt={photo.caption}
              loading="lazy"
              decoding="async"
            />
          </a>
          {(photo.caption || photo.place) && (
            <figcaption class="gallery-caption">
              <span class="caption-text">{photo.caption}</span>
              {photo.place && <span class="caption-place">{photo.place}</span>}
            </figcaption>
          )}
        </figure>
      ))}
    </div>
  </article>
</Layout>

<style>
  .gallery-page {
    padding: var(--space-xl) 0;
  }

  .gallery-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--space-xl);
    color: var(--color-text);
  }

  .gallery-empty {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  .gallery-empty code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: var(--color-code-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .gallery-item {
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .gallery-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .gallery-item a {
    display: block;
    line-height: 0;
  }

  .gallery-item img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }

  .gallery-item:hover img {
    opacity: 0.92;
  }

  .gallery-caption {
    padding: var(--space-sm) var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .caption-text {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .caption-place {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: var(--space-sm);
    }

    .gallery-item img {
      height: 160px;
    }
  }
</style>
