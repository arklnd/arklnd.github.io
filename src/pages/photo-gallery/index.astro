---
import Layout from "../../components/Layout.astro";
import ReactionsBadge from "../../components/ReactionsBadge.astro";
import photos, { albums } from "../../data/photos";

const isDev = import.meta.env.DEV;

const albumsWithCards = albums.map((album) => {
  const coverSlug = album.coverSlug ?? album.photoSlugs[0];
  const otherSlugs = album.photoSlugs.filter((s) => s !== coverSlug).slice(0, 3);
  const orderedSlugs = [...otherSlugs, coverSlug];
  const cards = orderedSlugs
    .map((slug) => photos.find((p) => p.slug === slug))
    .filter(Boolean);
  return { album, cards };
});
---

<Layout title="Photo Gallery" description="Photo Gallery">
  <article class="gallery-page">
    <h1 class="gallery-title">Photo Gallery</h1>

    {albums.length > 0 && (
      <section class="albums-section">
        <h2 class="albums-heading">Albums</h2>
        <div class="albums-grid">
          {albumsWithCards.map(({ album, cards }) => (
            <a href={`/photo-albums/${album.slug}`} class="album-hand">
              <div class="card-fan">
                {cards.map((photo, i) => (
                  <div
                    class="fan-card"
                    style={`--i: ${i}; --total: ${cards.length};`}
                  >
                    <img
                      src={isDev
                        ? `/images/gallery/${photo!.filename}`
                        : `/images/gallery/thumbs/${photo!.filename}.webp`}
                      alt={photo!.caption || album.title}
                      loading="lazy"
                      decoding="async"
                      onload="this.classList.add('loaded')"
                    />
                  </div>
                ))}
              </div>
              <div class="album-info">
                <span class="album-count">{album.photoSlugs.length} photo{album.photoSlugs.length !== 1 ? "s" : ""}</span>
                <h3 class="album-name">{album.title}</h3>
                {album.description && (
                  <p class="album-description">{album.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {photos.length === 0 && (
      <p class="gallery-empty">No photos yet. Add entries to <code>src/data/gallery.ts</code> and images to <code>public/images/gallery</code>.</p>
    )}

    <div class="gallery-grid">
      {photos.map((photo) => (
        <figure class="gallery-item">
          <div class="gallery-img-wrap">
            <a href={`/photo-gallery/${photo.slug}`}>
              <div class="img-loader"></div>
              <img
                src={isDev ? `/images/gallery/${photo.filename}` : `/images/gallery/thumbs/${photo.filename}.webp`}
                alt={photo.caption}
                loading="lazy"
                decoding="async"
                onload="this.previousElementSibling.style.display='none';this.classList.add('loaded')"
              />
            </a>
            <div class="gallery-reactions">
              <ReactionsBadge slug={`photo:${photo.slug}`} />
            </div>
            {(photo.caption || photo.place) && (
              <div class="gallery-overlay">
                <figcaption class="gallery-caption">
                  {photo.place && <span class="caption-place">{photo.place}</span>}
                  <span class="caption-text">{photo.caption}</span>
                </figcaption>
              </div>
            )}
          </div>
        </figure>
      ))}
    </div>
  </article>
</Layout>

<style>
  .gallery-page {
    padding: var(--space-xl) 0;
  }

  .gallery-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--space-xl);
    color: var(--color-text);
  }

  .gallery-empty {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  .gallery-empty code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: var(--color-code-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .gallery-grid {
    columns: 4 250px;
    column-gap: var(--space-md);
  }

  /* ── Albums section ── */
  .albums-section {
    margin-bottom: var(--space-xl);
  }

  .albums-heading {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .albums-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 3rem 2rem;
  }

  .album-hand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    gap: 1rem;
  }

  .card-fan {
    position: relative;
    width: 150px;
    height: 210px;
    perspective: 600px;
  }

  .fan-card {
    --angle: calc((var(--i) - (var(--total) - 1) / 2) * 8deg);
    --shift: calc((var(--i) - (var(--total) - 1) / 2) * 18px);
    position: absolute;
    inset: 0;
    border-radius: 10px;
    overflow: hidden;
    background: #1a1a1a;
    border: 2px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.5),
      0 1px 4px rgba(0, 0, 0, 0.3);
    transform-origin: bottom center;
    transform: translateX(var(--shift)) rotate(var(--angle));
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s ease;
  }

  .album-hand:hover .fan-card {
    --angle: calc((var(--i) - (var(--total) - 1) / 2) * 14deg);
    --shift: calc((var(--i) - (var(--total) - 1) / 2) * 28px);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.6),
      0 2px 8px rgba(0, 0, 0, 0.4);
  }

  .fan-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .fan-card img.loaded {
    opacity: 1;
  }

  .album-info {
    text-align: center;
    padding-top: 0.5rem;
  }

  .album-count {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    display: block;
    margin-bottom: 4px;
  }

  .album-name {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .album-description {
    font-family: var(--font-body);
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--color-text-tertiary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: 220px;
  }

  @media (max-width: 600px) {
    .card-fan {
      width: 130px;
      height: 180px;
    }
  }

  .gallery-item {
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.32), 0 2px 6px rgba(0, 0, 0, 0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    break-inside: avoid;
    margin-bottom: var(--space-md);
  }

  .gallery-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.14), 0 2px 6px rgba(0, 0, 0, 0.08);
  }

  .gallery-img-wrap {
    position: relative;
    line-height: 0;
  }

  .gallery-img-wrap a {
    display: block;
  }

  .img-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    z-index: 1;
  }

  .img-loader::after {
    content: "";
    width: 28px;
    height: 28px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-link);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s ease;
    opacity: 0;
  }

  .gallery-item img.loaded {
    opacity: 1;
  }

  .gallery-item:hover img {
    opacity: 0.92;
  }

  .gallery-caption {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.3;
  }

  .caption-text {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #fff;
  }

  .caption-place {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 10px 10px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    pointer-events: none;
  }

  .gallery-reactions {
    position: absolute;
    top: 6px;
    right: 6px;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .gallery-grid {
      columns: 2 150px;
      column-gap: var(--space-sm);
    }

    .gallery-item {
      margin-bottom: var(--space-sm);
    }
  }
</style>
