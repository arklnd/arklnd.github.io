---
import Layout from "../../components/Layout.astro";
import Reactions from "../../components/Reactions.astro";
import photos, { albums } from "../../data/photos";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import type { GalleryPhoto } from "../../data/photos";

export const getStaticPaths = (() => {
  return photos.map((photo) => ({
    params: { slug: photo.slug },
    props: { photo },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { photo } = Astro.props as Props;

const currentIndex = photos.findIndex((p) => p.slug === photo.slug);
const prevPhoto = currentIndex > 0 ? photos[currentIndex - 1] : null;
const nextPhoto = currentIndex < photos.length - 1 ? photos[currentIndex + 1] : null;

const formattedDate = new Date(photo.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const isDev = import.meta.env.DEV || import.meta.env.PUBLIC_LOCAL_DEV === "true";
const base = import.meta.env.BASE_URL;
const siteUrl = Astro.site?.origin || "https://arijitk.in";
const ogImage = `${siteUrl}/images/gallery/og/${photo.filename}.jpg`;
const displayImage = isDev ? `${base}images/gallery/${photo.filename}` : `${base}images/gallery/display/${photo.filename}.webp`;
const pageUrl = `${siteUrl}/photo-gallery/${photo.slug}`;

// ── SEO: build rich description & keywords ──
const photoAlbums = albums.filter((a) => a.photoSlugs.includes(photo.slug));
const altText = photo.alt || photo.caption;

const description = photo.caption
  ? `${photo.caption}${photo.place ? ` — ${photo.place}` : ""}`
  : photo.place
    ? `Photo taken at ${photo.place} on ${formattedDate}`
    : `Photo by Arijit Kundu — ${formattedDate}`;

const keywords = [
  ...(photo.tags ?? []),
  ...(photo.place ? [photo.place] : []),
  ...(photo.camera ? [photo.camera] : []),
  ...photoAlbums.map((a) => a.title),
  "photography",
  "Arijit Kundu",
].join(", ");

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ImageObject",
  name: photo.caption || altText,
  description,
  contentUrl: ogImage,
  url: pageUrl,
  datePublished: photo.date,
  ...(photo.place && { contentLocation: { "@type": "Place", name: photo.place } }),
  ...(photo.camera && { exifData: [{ "@type": "PropertyValue", name: "camera", value: photo.camera }] }),
  ...(photo.tags?.length && { keywords: photo.tags.join(", ") }),
  ...(photoAlbums.length && { isPartOf: photoAlbums.map((a) => ({ "@type": "ImageGallery", name: a.title, url: `${siteUrl}/photo-albums/${a.slug}` })) }),
  author: { "@type": "Person", name: "Arijit Kundu" },
});
const albumMap: Record<string, string> = Object.fromEntries(
  albums.map((a) => [a.slug, a.title])
);
---

<Layout title={photo.caption || altText} description={description} ogImage={ogImage} bare>
  <Fragment slot="head">
    <meta name="keywords" content={keywords} />
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>
  <article class="photo-viewer">
    <div class="ambient-bg" aria-hidden="true">
      <img src={displayImage} alt="" />
    </div>
    <div class="viewer-canvas" id="viewer-canvas">
      <div class="img-loader"></div>
      <img
        src={displayImage}
        alt={altText}
        loading="eager"
        decoding="async"
        onload="this.previousElementSibling.style.display='none';this.classList.add('loaded')"
      />
    </div>

    <div class="viewer-overlay top-bar">
      <a href={`${base}photo-gallery`} class="back-link" id="back-link">&larr; Back to Gallery</a>
    </div>

    <div class="viewer-overlay bottom-bar">
      <div class="photo-info">
        <h1 class="photo-caption">{photo.caption}</h1>
        <div class="photo-meta">
          <time datetime={photo.date}>{formattedDate}</time>
          {photo.place && (
            <span class="photo-place">{photo.place}</span>
          )}
        </div>
        {photoAlbums.length > 0 && (
          <div class="photo-albums">
            {photoAlbums.map((album) => (
              <a href={`${base}photo-albums/${album.slug}`} class="album-pill">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                {album.title}
              </a>
            ))}
          </div>
        )}
        <Reactions slug={`photo:${photo.slug}`} />
      </div>
    </div>

    <nav class="viewer-overlay nav-overlay" aria-label="Photo navigation">
      {prevPhoto ? (
        <a href={`${base}photo-gallery/${prevPhoto.slug}`} class="nav-prev" aria-label="Previous photo">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
      ) : (
        <span class="nav-disabled"></span>
      )}
      {nextPhoto ? (
        <a href={`${base}photo-gallery/${nextPhoto.slug}`} class="nav-next" aria-label="Next photo">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      ) : (
        <span class="nav-disabled"></span>
      )}
    </nav>
  </article>
</Layout>

<style>
  :global(.page:has(.photo-viewer)) {
    max-width: 100dvw;
    padding-inline: 0;
  }

  .photo-viewer {
    position: relative;
    width: 100dvw;
    height: 100dvh;
    overflow: hidden;
    background: #0d0d0d;
  }

  .ambient-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .ambient-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(60px) saturate(2.2) brightness(0.42);
    transform: scale(1.15);
    opacity: 1;
    will-change: filter;
  }

  .viewer-canvas {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    touch-action: pan-y;
    user-select: none;
  }

  .viewer-canvas img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.3s ease;
    opacity: 0;
    transform-origin: center center;
    will-change: transform;
    cursor: zoom-in;
  }

  .viewer-canvas img.zoomed {
    cursor: grab;
  }

  .viewer-canvas img.dragging {
    cursor: grabbing;
  }

  .viewer-canvas img.loaded {
    opacity: 1;
  }

  .img-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .img-loader::after {
    content: "";
    width: 36px;
    height: 36px;
    border: 3px solid rgba(255, 255, 255, 0.2);
    border-top-color: var(--color-link);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ── Overlay layers ── */
  .viewer-overlay {
    position: absolute;
    z-index: 10;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .viewer-overlay > * {
    pointer-events: auto;
  }

  .photo-viewer.overlays-hidden .viewer-overlay {
    opacity: 0;
    pointer-events: none !important;
  }

  .photo-viewer.overlays-hidden .viewer-overlay > * {
    pointer-events: none;
  }

  .top-bar {
    top: 0;
    left: 0;
    right: 0;
    padding: var(--space-md) var(--space-lg);
    background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, transparent 100%);
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    transition: opacity 0.15s ease;
    opacity: 0.85;
  }

  .back-link:hover {
    opacity: 1;
  }

  .bottom-bar {
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-xl) var(--space-lg) var(--space-lg);
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
  }

  .photo-info {
    max-width: 600px;
  }

  .photo-albums {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: var(--space-sm);
  }

  .album-pill,
  .album-pill:visited {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.65rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .album-pill:hover {
    background: rgba(255, 255, 255, 0.22);
    border-color: rgba(255, 255, 255, 0.45);
    color: #fff;
  }

  .photo-caption {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: var(--space-xs);
  }

  .photo-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-sm);
  }

  .photo-place::before {
    content: "\2022";
    margin-right: var(--space-md);
    color: rgba(255, 255, 255, 0.4);
  }

  /* ── Nav arrows ── */
  .nav-overlay {
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 var(--space-md);
  }

  .nav-overlay a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    line-height: 1;
    text-decoration: none;
    transition: background 0.15s ease, opacity 0.15s ease;
    opacity: 0.7;
  }

  .nav-overlay a:hover {
    background: rgba(0, 0, 0, 0.7);
    opacity: 1;
  }

  .nav-overlay .nav-disabled {
    width: 44px;
    height: 44px;
    opacity: 0;
    pointer-events: none;
  }

  :global(.dbl-tap-heart) {
    position: absolute;
    font-size: 4rem;
    pointer-events: none;
    transform: translate(-50%, -50%) scale(0);
    animation: heart-pop 0.8s ease forwards;
    z-index: 20;
  }

  @keyframes heart-pop {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 1; }
    50% { transform: translate(-50%, -50%) scale(1.3); opacity: 1; }
    100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
  }

  /* ── Reactions styling override for dark bg ── */
  .bottom-bar :global(.reactions) {
    --color-text-secondary: rgba(255, 255, 255, 0.85);
    --color-border: rgba(255, 255, 255, 0.35);
    --color-surface: rgba(255, 255, 255, 0.1);
    --color-link: #7fd4e1;
  }

  /* ── Picker opens upward in the photo viewer ── */
  .bottom-bar :global(.reaction-picker) {
    top: auto;
    bottom: 100%;
    margin-top: 0;
    margin-bottom: var(--space-sm);
    background: rgba(20, 24, 30, 0.55);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.45), 0 0 0 0.5px rgba(255,255,255,0.08) inset;
    color: rgba(255, 255, 255, 0.9);
  }

  .bottom-bar :global(.picker-search) {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.9);
  }

  .bottom-bar :global(.picker-search::placeholder) {
    color: rgba(255, 255, 255, 0.45);
  }

  .bottom-bar :global(.picker-group-label) {
    color: rgba(255, 255, 255, 0.45);
  }

  .bottom-bar :global(.reactions-bar .reaction-btn) {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .bottom-bar :global(.reaction-add-btn) {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  @media (max-width: 600px) {
    .photo-caption {
      font-size: 1.1rem;
    }

    .photo-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .photo-place::before {
      display: none;
    }

    .nav-overlay a {
      width: 36px;
      height: 36px;
      font-size: 1rem;
    }
  }
</style>

<script define:vars={{ prevUrl: prevPhoto ? `${import.meta.env.BASE_URL}photo-gallery/${prevPhoto.slug}` : null, nextUrl: nextPhoto ? `${import.meta.env.BASE_URL}photo-gallery/${nextPhoto.slug}` : null, albumMap, baseUrl: import.meta.env.BASE_URL }}>
  const frame = document.getElementById("viewer-canvas");
  const img = frame ? frame.querySelector("img") : null;
  if (!frame || !img) return;

  // ── State ──
  let scale = 1;
  let tx = 0;        // accumulated pan X (screen px)
  let ty = 0;        // accumulated pan Y (screen px)
  let isPinching = false;
  let startScale = 1;
  let startDist = 0;
  let startPanX = 0; // clientX at pan-start minus current tx
  let startPanY = 0;
  let swipeStartX = 0;
  let lastTap = 0;
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;

  const MIN_SWIPE = 50;
  const MAX_SCALE = 5;

  function pinchDist(t1, t2) {
    return Math.hypot(t1.clientX - t2.clientX, t1.clientY - t2.clientY);
  }

  function clamp(val, min, max) {
    return Math.min(max, Math.max(min, val));
  }

  function applyTransform(animate) {
    // Clamp pan so the image edge doesn't go past the frame centre
    if (scale > 1) {
      const maxX = (frame.offsetWidth  * (scale - 1)) / 2;
      const maxY = (frame.offsetHeight * (scale - 1)) / 2;
      tx = clamp(tx, -maxX, maxX);
      ty = clamp(ty, -maxY, maxY);
    } else {
      tx = 0;
      ty = 0;
    }

    if (animate) img.style.transition = "transform 0.22s ease";
    img.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    if (animate) setTimeout(() => { img.style.transition = ""; }, 230);

    img.classList.toggle("zoomed", scale > 1);
    img.classList.remove("dragging");
    // Let the browser handle page scroll only when not zoomed
    frame.style.touchAction = scale > 1 ? "none" : "pan-y";
  }

  function resetZoom(animate) {
    scale = 1; tx = 0; ty = 0;
    applyTransform(animate);
  }

  // ── Touch handlers ──
  let touchFingers = 0; // track max fingers used during gesture
  let swipeStartY = 0;
  let pinchMidX = 0;
  let pinchMidY = 0;
  let pinchStartTx = 0;
  let pinchStartTy = 0;

  function onTouchStart(e) {
    if (e.touches.length === 2) {
      isPinching = true;
      touchFingers = 2;
      startDist  = pinchDist(e.touches[0], e.touches[1]);
      startScale = scale;
      // Store pinch midpoint relative to frame centre
      const rect = frame.getBoundingClientRect();
      const midX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
      const midY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
      pinchMidX = midX - rect.left - rect.width / 2;
      pinchMidY = midY - rect.top - rect.height / 2;
      pinchStartTx = tx;
      pinchStartTy = ty;
      e.preventDefault();
    } else if (e.touches.length === 1) {
      touchFingers = 1;
      swipeStartX = e.touches[0].clientX;
      swipeStartY = e.touches[0].clientY;
      if (scale > 1) {
        startPanX = e.touches[0].clientX - tx;
        startPanY = e.touches[0].clientY - ty;
      }
    }
  }

  function onTouchMove(e) {
    if (e.touches.length === 2) {
      touchFingers = 2; // mark as multi-finger even if started as 1
      if (isPinching) {
        const newScale = clamp(
          startScale * (pinchDist(e.touches[0], e.touches[1]) / startDist),
          1, MAX_SCALE
        );
        // Keep the pinch midpoint stationary (same logic as wheel zoom)
        tx = pinchMidX - (pinchMidX - pinchStartTx) * (newScale / startScale);
        ty = pinchMidY - (pinchMidY - pinchStartTy) * (newScale / startScale);
        scale = newScale;
        applyTransform(false);
        e.preventDefault();
      }
    } else if (e.touches.length === 1 && scale > 1) {
      tx = e.touches[0].clientX - startPanX;
      ty = e.touches[0].clientY - startPanY;
      applyTransform(false);
      e.preventDefault();
    }
  }

  function onTouchEnd(e) {
    if (isPinching) {
      isPinching = false;
      // Snap back to 1 if barely zoomed
      if (scale < 1.12) resetZoom(true);
      touchFingers = 0;
      return; // never navigate after a pinch gesture
    }

    // Never swipe if two fingers were used at any point
    if (touchFingers >= 2) {
      touchFingers = 0;
      return;
    }
    touchFingers = 0;

    // Double-tap to reset zoom or trigger love reaction
    const now = Date.now();
    if (now - lastTap < 280 && e.changedTouches.length === 1) {
      if (scale > 1) resetZoom(true);
      else triggerLoveReaction(e.changedTouches[0].clientX, e.changedTouches[0].clientY);
      lastTap = 0;
      return;
    }
    lastTap = now;

    // Block swipe when zoomed
    if (scale > 1) return;

    const dx = swipeStartX - e.changedTouches[0].clientX;
    const dy = swipeStartY - e.changedTouches[0].clientY;

    // Only swipe if horizontal distance is significant AND
    // horizontal movement dominates vertical (ratio > 2:1)
    if (Math.abs(dx) < MIN_SWIPE) return;
    if (Math.abs(dy) > Math.abs(dx) * 0.5) return;

    if (dx > 0 && nextUrl) window.location.href = nextUrl;
    else if (dx < 0 && prevUrl) window.location.href = prevUrl;
  }

  // ── Single click toggles overlays ──
  const viewer = document.querySelector(".photo-viewer");
  let singleClickTimer = null;
  frame.addEventListener("click", (e) => {
    // Ignore if this was a drag or a nav/reaction link click
    if (isDragging) return;
    if (e.target.closest("a, button")) return;
    // Use a short delay so double-click can cancel it
    clearTimeout(singleClickTimer);
    singleClickTimer = setTimeout(() => {
      viewer?.classList.toggle("overlays-hidden");
    }, 220);
  });
  frame.addEventListener("dblclick", () => {
    clearTimeout(singleClickTimer);
  });

  frame.addEventListener("touchstart", onTouchStart, { passive: false });
  frame.addEventListener("touchmove",  onTouchMove,  { passive: false });
  frame.addEventListener("touchend",   onTouchEnd);

  // ── Mouse wheel zoom (desktop) ──
  function onWheel(e) {
    e.preventDefault();
    const rect = frame.getBoundingClientRect();
    // Mouse position relative to frame centre
    const mx = e.clientX - rect.left - rect.width  / 2;
    const my = e.clientY - rect.top  - rect.height / 2;

    const factor = Math.exp(-e.deltaY * 0.003);
    const newScale = clamp(scale * factor, 1, MAX_SCALE);

    if (newScale === scale) return;

    // Keep the image point under the cursor stationary
    tx = mx - (mx - tx) * (newScale / scale);
    ty = my - (my - ty) * (newScale / scale);
    scale = newScale;
    applyTransform(false);
  }

  // ── Mouse drag pan (desktop) ──
  function onMouseDown(e) {
    if (scale <= 1) return;
    if (e.button !== 0) return;
    isDragging = true;
    dragStartX = e.clientX - tx;
    dragStartY = e.clientY - ty;
    img.classList.add("dragging");
    e.preventDefault();
  }

  function onMouseMove(e) {
    if (!isDragging) return;
    tx = e.clientX - dragStartX;
    ty = e.clientY - dragStartY;
    applyTransform(false);
  }

  function onMouseUp() {
    if (!isDragging) return;
    isDragging = false;
    img.classList.remove("dragging");
  }

  // Double-click to reset zoom or trigger love reaction
  function onDblClick(e) {
    if (scale > 1) { resetZoom(true); e.preventDefault(); }
    else { triggerLoveReaction(e.clientX, e.clientY); e.preventDefault(); }
  }

  // ── Double-tap/click love reaction ──
  function triggerLoveReaction(x, y) {
    // Show heart animation
    const heart = document.createElement("span");
    heart.className = "dbl-tap-heart";
    heart.textContent = "❤️";
    const rect = frame.getBoundingClientRect();
    heart.style.left = (x - rect.left) + "px";
    heart.style.top = (y - rect.top) + "px";
    frame.appendChild(heart);
    heart.addEventListener("animationend", () => heart.remove());

    // Trigger the reaction
    if (window.__reactionsToggle) {
      const state = window.__reactionsState;
      // Only add if user hasn't already reacted with ❤️
      if (!state || !state.userReactions.includes("❤️")) {
        window.__reactionsToggle("❤️");
      }
    }
  }

  // ── Arrow key navigation & zoom ──
  function onKeyDown(e) {
    if (e.key === "ArrowUp" || e.key === "ArrowDown") {
      e.preventDefault();
      const factor = e.key === "ArrowUp" ? 1.25 : 1 / 1.25;
      const newScale = clamp(scale * factor, 1, MAX_SCALE);
      if (newScale !== scale) {
        tx = tx * (newScale / scale);
        ty = ty * (newScale / scale);
        scale = newScale;
        applyTransform(true);
      }
      return;
    }
    if (scale > 1) return; // don't navigate while zoomed
    if (e.key === "ArrowLeft" && prevUrl) { e.preventDefault(); window.location.href = prevUrl; }
    else if (e.key === "ArrowRight" && nextUrl) { e.preventDefault(); window.location.href = nextUrl; }
  }

  document.addEventListener("keydown", onKeyDown);
  frame.addEventListener("wheel",      onWheel,     { passive: false });
  frame.addEventListener("mousedown",  onMouseDown);
  frame.addEventListener("dblclick",   onDblClick);
  document.addEventListener("mousemove", onMouseMove);
  document.addEventListener("mouseup",   onMouseUp);

  document.addEventListener("astro:before-swap", () => {
    frame.removeEventListener("touchstart", onTouchStart);
    frame.removeEventListener("touchmove",  onTouchMove);
    frame.removeEventListener("touchend",   onTouchEnd);
    frame.removeEventListener("wheel",      onWheel);
    frame.removeEventListener("mousedown",  onMouseDown);
    frame.removeEventListener("dblclick",   onDblClick);
    document.removeEventListener("mousemove", onMouseMove);
    document.removeEventListener("mouseup",   onMouseUp);
    document.removeEventListener("keydown",   onKeyDown);
    clearTimeout(singleClickTimer);
  }, { once: true });

  // ── Dynamic back link ──
  function updateBackLink() {
    const link = document.getElementById("back-link");
    if (!link) return;

    let refUrl = null;

    // Navigation API — works with Astro view transitions (SPA nav)
    if (typeof navigation !== "undefined" && navigation.entries) {
      const entries = navigation.entries();
      const idx = entries.findIndex((e) => e.key === navigation.currentEntry?.key);
      if (idx > 0) refUrl = entries[idx - 1].url;
    }

    // Fallback for full-page loads
    if (!refUrl && document.referrer) refUrl = document.referrer;

    if (!refUrl) return;

    const match = refUrl.match(/\/photo-albums\/([^/?#]+)/);
    if (match) {
      const slug = match[1];
      const title = albumMap[slug];
      link.href = title ? `${baseUrl}photo-albums/${slug}` : `${baseUrl}photo-albums`;
      link.textContent = `\u2190 Back to ${title ?? "Albums"}`;
    }
    // If referrer was /photo-albums (index), point there
    else if (refUrl.includes("/photo-albums")) {
      link.href = `${baseUrl}photo-albums`;
      link.textContent = "\u2190 Back to Albums";
    }
    // else keep default "← Back to Gallery"
  }

  document.addEventListener("astro:page-load", updateBackLink);
  updateBackLink();
</script>
