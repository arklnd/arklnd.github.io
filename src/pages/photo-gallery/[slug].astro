---
import Layout from "../../components/Layout.astro";
import Reactions from "../../components/Reactions.astro";
import photos, { albums } from "../../data/photos";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import type { GalleryPhoto } from "../../data/photos";

export const getStaticPaths = (() => {
  return photos.map((photo) => ({
    params: { slug: photo.slug },
    props: { photo },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { photo } = Astro.props as Props;

const currentIndex = photos.findIndex((p) => p.slug === photo.slug);
const prevPhoto = currentIndex > 0 ? photos[currentIndex - 1] : null;
const nextPhoto = currentIndex < photos.length - 1 ? photos[currentIndex + 1] : null;

const formattedDate = new Date(photo.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const isDev = import.meta.env.DEV;
const siteUrl = Astro.site?.origin || "https://arijitk.in";
const ogImage = `${siteUrl}/images/gallery/og/${photo.filename}.jpg`;
const displayImage = isDev ? `/images/gallery/${photo.filename}` : `/images/gallery/display/${photo.filename}.webp`;
const pageUrl = `${siteUrl}/photo-gallery/${photo.slug}`;
const description = `${photo.caption}${photo.place ? ` — ${photo.place}` : ""}`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ImageObject",
  name: photo.caption,
  description,
  contentUrl: ogImage,
  url: pageUrl,
  datePublished: photo.date,
  ...(photo.place && { contentLocation: { "@type": "Place", name: photo.place } }),
  author: { "@type": "Person", name: "Arijit Kundu" },
});
const albumMap: Record<string, string> = Object.fromEntries(
  albums.map((a) => [a.slug, a.title])
);
---

<Layout title={photo.caption} description={description} ogImage={ogImage} bare>
  <script slot="head" type="application/ld+json" set:html={jsonLd} />
  <article class="photo-viewer">
    <a href="/photo-gallery" class="back-link" id="back-link">&larr; Back to Gallery</a>

    <figure class="photo-frame">
      <div class="img-loader"></div>
      <img
        src={displayImage}
        alt={photo.caption}
        loading="eager"
        decoding="async"
        onload="this.previousElementSibling.style.display='none';this.classList.add('loaded')"
      />
      <button class="fullscreen-btn" id="fullscreen-btn" aria-label="Toggle fullscreen" title="Toggle fullscreen">
        <svg class="fs-expand" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>
        <svg class="fs-shrink" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14h6v6"/><path d="M20 10h-6V4"/><path d="M14 10l7-7"/><path d="M3 21l7-7"/></svg>
      </button>
    </figure>

    <div class="photo-info">
      <h1 class="photo-caption">{photo.caption}</h1>
      <div class="photo-meta">
        <time datetime={photo.date}>{formattedDate}</time>
        {photo.place && (
          <span class="photo-place">{photo.place}</span>
        )}
      </div>
      <Reactions slug={`photo:${photo.slug}`} />
    </div>

    <nav class="photo-nav" aria-label="Photo navigation">
      {prevPhoto ? (
        <a href={`/photo-gallery/${prevPhoto.slug}`} class="nav-prev">&larr; Previous</a>
      ) : (
        <span class="nav-disabled">&larr; Previous</span>
      )}
      {nextPhoto ? (
        <a href={`/photo-gallery/${nextPhoto.slug}`} class="nav-next">Next &rarr;</a>
      ) : (
        <span class="nav-disabled">Next &rarr;</span>
      )}
    </nav>
  </article>
</Layout>

<style>
  :global(.page:has(.photo-viewer)) {
    max-width: 95dvw;
    padding-inline: 0;
  }

  @media (max-width: 600px) {
    :global(.page:has(.photo-viewer)) {
      max-width: 100%;
    }
  }

  .photo-viewer {
    padding: var(--space-xl) var(--space-md);
    max-width: 100%;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: var(--space-lg);
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-link);
  }

  .photo-frame {
    border-radius: 0;
    overflow: hidden;
    background: var(--color-frame);
    border: 1px solid var(--color-frame-border);
    padding: 8px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    margin-bottom: var(--space-lg);
    touch-action: pan-y;
    user-select: none;
    position: relative;
  }

  .fullscreen-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 10;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    border-radius: 6px;
    color: #fff;
    padding: 8px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, background 0.15s ease;
    line-height: 0;
  }

  .photo-frame:hover .fullscreen-btn,
  .photo-frame:focus-within .fullscreen-btn {
    opacity: 1;
  }

  .fullscreen-btn:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  .fullscreen-btn .fs-shrink {
    display: none;
  }

  :global(:fullscreen) .fullscreen-btn .fs-expand {
    display: none;
  }

  :global(:fullscreen) .fullscreen-btn .fs-shrink {
    display: inline;
  }

  :global(:fullscreen) .fullscreen-btn {
    opacity: 1;
  }

  :global(.photo-frame:fullscreen) {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    padding: 0;
    border: none;
  }

  :global(.photo-frame:fullscreen) img {
    max-height: 100vh;
    max-width: 100vw;
    width: auto;
    object-fit: contain;
  }

  :global(.dbl-tap-heart) {
    position: absolute;
    font-size: 4rem;
    pointer-events: none;
    transform: translate(-50%, -50%) scale(0);
    animation: heart-pop 0.8s ease forwards;
    z-index: 10;
  }

  @keyframes heart-pop {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 1; }
    50% { transform: translate(-50%, -50%) scale(1.3); opacity: 1; }
    100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
  }

  .img-loader {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    background: var(--color-surface);
  }

  .img-loader::after {
    content: "";
    width: 36px;
    height: 36px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-link);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .photo-frame img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
    transition: opacity 0.3s ease;
    opacity: 0;
    transform-origin: center center;
    will-change: transform;
    cursor: zoom-in;
  }

  .photo-frame img.zoomed {
    cursor: grab;
  }

  .photo-frame img.dragging {
    cursor: grabbing;
  }

  .photo-frame img.loaded {
    opacity: 1;
  }

  .photo-info {
    margin-bottom: var(--space-xl);
  }

  .photo-caption {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .photo-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-family: var(--font-heading);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .photo-place::before {
    content: "\2022";
    margin-right: var(--space-md);
    color: var(--color-border);
  }

  .photo-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .photo-nav a {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .photo-nav a:hover {
    color: var(--color-link-hover);
  }

  .nav-disabled {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    color: var(--color-border);
    user-select: none;
  }

  @media (max-width: 600px) {
    .photo-caption {
      font-size: 1.25rem;
    }

    .photo-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .photo-place::before {
      display: none;
    }

    .fullscreen-btn {
      opacity: 1;
    }
  }
</style>

<script define:vars={{ prevUrl: prevPhoto ? `/photo-gallery/${prevPhoto.slug}` : null, nextUrl: nextPhoto ? `/photo-gallery/${nextPhoto.slug}` : null, albumMap }}>
  const frame = document.querySelector(".photo-frame");
  const img = frame ? frame.querySelector("img") : null;
  if (!frame || !img) return;

  // ── State ──
  let scale = 1;
  let tx = 0;        // accumulated pan X (screen px)
  let ty = 0;        // accumulated pan Y (screen px)
  let isPinching = false;
  let startScale = 1;
  let startDist = 0;
  let startPanX = 0; // clientX at pan-start minus current tx
  let startPanY = 0;
  let swipeStartX = 0;
  let lastTap = 0;
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;

  const MIN_SWIPE = 50;
  const MAX_SCALE = 5;

  function pinchDist(t1, t2) {
    return Math.hypot(t1.clientX - t2.clientX, t1.clientY - t2.clientY);
  }

  function clamp(val, min, max) {
    return Math.min(max, Math.max(min, val));
  }

  function applyTransform(animate) {
    // Clamp pan so the image edge doesn't go past the frame centre
    if (scale > 1) {
      const maxX = (frame.offsetWidth  * (scale - 1)) / 2;
      const maxY = (frame.offsetHeight * (scale - 1)) / 2;
      tx = clamp(tx, -maxX, maxX);
      ty = clamp(ty, -maxY, maxY);
    } else {
      tx = 0;
      ty = 0;
    }

    if (animate) img.style.transition = "transform 0.22s ease";
    img.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    if (animate) setTimeout(() => { img.style.transition = ""; }, 230);

    img.classList.toggle("zoomed", scale > 1);
    img.classList.remove("dragging");
    // Let the browser handle page scroll only when not zoomed
    frame.style.touchAction = scale > 1 ? "none" : "pan-y";
  }

  function resetZoom(animate) {
    scale = 1; tx = 0; ty = 0;
    applyTransform(animate);
  }

  // ── Touch handlers ──
  let touchFingers = 0; // track max fingers used during gesture
  let swipeStartY = 0;

  function onTouchStart(e) {
    if (e.touches.length === 2) {
      isPinching = true;
      touchFingers = 2;
      startDist  = pinchDist(e.touches[0], e.touches[1]);
      startScale = scale;
      e.preventDefault();
    } else if (e.touches.length === 1) {
      touchFingers = 1;
      swipeStartX = e.touches[0].clientX;
      swipeStartY = e.touches[0].clientY;
      if (scale > 1) {
        startPanX = e.touches[0].clientX - tx;
        startPanY = e.touches[0].clientY - ty;
      }
    }
  }

  function onTouchMove(e) {
    if (e.touches.length === 2) {
      touchFingers = 2; // mark as multi-finger even if started as 1
      if (isPinching) {
        scale = clamp(
          startScale * (pinchDist(e.touches[0], e.touches[1]) / startDist),
          1, MAX_SCALE
        );
        applyTransform(false);
        e.preventDefault();
      }
    } else if (e.touches.length === 1 && scale > 1) {
      tx = e.touches[0].clientX - startPanX;
      ty = e.touches[0].clientY - startPanY;
      applyTransform(false);
      e.preventDefault();
    }
  }

  function onTouchEnd(e) {
    if (isPinching) {
      isPinching = false;
      // Snap back to 1 if barely zoomed
      if (scale < 1.12) resetZoom(true);
      touchFingers = 0;
      return; // never navigate after a pinch gesture
    }

    // Never swipe if two fingers were used at any point
    if (touchFingers >= 2) {
      touchFingers = 0;
      return;
    }
    touchFingers = 0;

    // Double-tap to reset zoom or trigger love reaction
    const now = Date.now();
    if (now - lastTap < 280 && e.changedTouches.length === 1) {
      if (scale > 1) resetZoom(true);
      else triggerLoveReaction(e.changedTouches[0].clientX, e.changedTouches[0].clientY);
      lastTap = 0;
      return;
    }
    lastTap = now;

    // Block swipe when zoomed
    if (scale > 1) return;

    const dx = swipeStartX - e.changedTouches[0].clientX;
    const dy = swipeStartY - e.changedTouches[0].clientY;

    // Only swipe if horizontal distance is significant AND
    // horizontal movement dominates vertical (ratio > 2:1)
    if (Math.abs(dx) < MIN_SWIPE) return;
    if (Math.abs(dy) > Math.abs(dx) * 0.5) return;

    if (dx > 0 && nextUrl) window.location.href = nextUrl;
    else if (dx < 0 && prevUrl) window.location.href = prevUrl;
  }

  frame.addEventListener("touchstart", onTouchStart, { passive: false });
  frame.addEventListener("touchmove",  onTouchMove,  { passive: false });
  frame.addEventListener("touchend",   onTouchEnd);

  // ── Mouse wheel zoom (desktop) ──
  function onWheel(e) {
    e.preventDefault();
    const rect = frame.getBoundingClientRect();
    // Mouse position relative to frame centre
    const mx = e.clientX - rect.left - rect.width  / 2;
    const my = e.clientY - rect.top  - rect.height / 2;

    const factor = Math.exp(-e.deltaY * 0.003);
    const newScale = clamp(scale * factor, 1, MAX_SCALE);

    if (newScale === scale) return;

    // Keep the image point under the cursor stationary
    tx = mx - (mx - tx) * (newScale / scale);
    ty = my - (my - ty) * (newScale / scale);
    scale = newScale;
    applyTransform(false);
  }

  // ── Mouse drag pan (desktop) ──
  function onMouseDown(e) {
    if (scale <= 1) return;
    if (e.button !== 0) return;
    isDragging = true;
    dragStartX = e.clientX - tx;
    dragStartY = e.clientY - ty;
    img.classList.add("dragging");
    e.preventDefault();
  }

  function onMouseMove(e) {
    if (!isDragging) return;
    tx = e.clientX - dragStartX;
    ty = e.clientY - dragStartY;
    applyTransform(false);
  }

  function onMouseUp() {
    if (!isDragging) return;
    isDragging = false;
    img.classList.remove("dragging");
  }

  // Double-click to reset zoom or trigger love reaction
  function onDblClick(e) {
    if (scale > 1) { resetZoom(true); e.preventDefault(); }
    else { triggerLoveReaction(e.clientX, e.clientY); e.preventDefault(); }
  }

  // ── Double-tap/click love reaction ──
  function triggerLoveReaction(x, y) {
    // Show heart animation
    const heart = document.createElement("span");
    heart.className = "dbl-tap-heart";
    heart.textContent = "❤️";
    const rect = frame.getBoundingClientRect();
    heart.style.left = (x - rect.left) + "px";
    heart.style.top = (y - rect.top) + "px";
    frame.appendChild(heart);
    heart.addEventListener("animationend", () => heart.remove());

    // Trigger the reaction
    if (window.__reactionsToggle) {
      const state = window.__reactionsState;
      // Only add if user hasn't already reacted with ❤️
      if (!state || !state.userReactions.includes("❤️")) {
        window.__reactionsToggle("❤️");
      }
    }
  }

  frame.addEventListener("wheel",      onWheel,     { passive: false });
  frame.addEventListener("mousedown",  onMouseDown);
  frame.addEventListener("dblclick",   onDblClick);
  document.addEventListener("mousemove", onMouseMove);
  document.addEventListener("mouseup",   onMouseUp);

  // ── Fullscreen toggle ──
  const fsBtn = document.getElementById("fullscreen-btn");
  function toggleFullscreen() {
    if (!document.fullscreenElement) {
      frame.requestFullscreen().catch(() => {});
    } else {
      document.exitFullscreen();
    }
  }
  if (fsBtn) fsBtn.addEventListener("click", toggleFullscreen);

  document.addEventListener("astro:before-swap", () => {
    frame.removeEventListener("touchstart", onTouchStart);
    frame.removeEventListener("touchmove",  onTouchMove);
    frame.removeEventListener("touchend",   onTouchEnd);
    frame.removeEventListener("wheel",      onWheel);
    frame.removeEventListener("mousedown",  onMouseDown);
    frame.removeEventListener("dblclick",   onDblClick);
    document.removeEventListener("mousemove", onMouseMove);
    document.removeEventListener("mouseup",   onMouseUp);
    if (fsBtn) fsBtn.removeEventListener("click", toggleFullscreen);
    if (document.fullscreenElement) document.exitFullscreen();
  }, { once: true });

  // ── Dynamic back link ──
  function updateBackLink() {
    const link = document.getElementById("back-link");
    if (!link) return;

    let refUrl = null;

    // Navigation API — works with Astro view transitions (SPA nav)
    if (typeof navigation !== "undefined" && navigation.entries) {
      const entries = navigation.entries();
      const idx = entries.findIndex((e) => e.key === navigation.currentEntry?.key);
      if (idx > 0) refUrl = entries[idx - 1].url;
    }

    // Fallback for full-page loads
    if (!refUrl && document.referrer) refUrl = document.referrer;

    if (!refUrl) return;

    const match = refUrl.match(/\/photo-albums\/([^/?#]+)/);
    if (match) {
      const slug = match[1];
      const title = albumMap[slug];
      link.href = title ? `/photo-albums/${slug}` : "/photo-albums";
      link.textContent = `\u2190 Back to ${title ?? "Albums"}`;
    }
    // If referrer was /photo-albums (index), point there
    else if (refUrl.includes("/photo-albums")) {
      link.href = "/photo-albums";
      link.textContent = "\u2190 Back to Albums";
    }
    // else keep default "← Back to Gallery"
  }

  document.addEventListener("astro:page-load", updateBackLink);
  updateBackLink();
</script>
