---
import { getCollection, render } from "astro:content";
import "../../styles/global.css";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} — Presentation</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,500;0,7..72,600;0,7..72,700;1,7..72,400;1,7..72,500&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <!-- Prevent FOUC: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem("theme");
        if (stored === "dark" || stored === "light") {
          document.documentElement.dataset.theme = stored;
        } else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.dataset.theme = "dark";
        } else {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
  </head>
  <body>
    <!-- Hidden source: rendered markdown content, sliced into slides by JS -->
    <div id="content-source" aria-hidden="true" style="display:none">
      <Content />
    </div>

    <!-- Deck layout -->
    <div class="deck">
      <!-- Header: breadcrumb + navigation -->
      <header class="deck-header">
        <div id="deck-heading" class="deck-heading" aria-live="polite"></div>
        <div class="deck-controls">
          <span class="deck-hint">← → navigate &nbsp;·&nbsp; L laser &nbsp;·&nbsp; F fullscreen &nbsp;·&nbsp; Esc exit</span>
          <button id="prev-btn" class="deck-btn" aria-label="Previous slide" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <span id="counter" class="deck-counter" aria-live="polite">1 / 1</span>
          <button id="next-btn" class="deck-btn" aria-label="Next slide">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
          <button id="deck-split-toggle" class="deck-btn" aria-label="Toggle auto-split" title="Toggle auto-split slides" aria-pressed="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="3" width="20" height="7" rx="1"/>
              <rect x="2" y="14" width="20" height="7" rx="1"/>
            </svg>
          </button>
          <button id="deck-laser-toggle" class="deck-btn" aria-label="Toggle laser pointer" title="Toggle laser pointer (L)" aria-pressed="false">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <line x1="12" y1="2" x2="12" y2="5"/>
              <line x1="12" y1="19" x2="12" y2="22"/>
              <line x1="2" y1="12" x2="5" y2="12"/>
              <line x1="19" y1="12" x2="22" y2="12"/>
            </svg>
          </button>
          <button id="deck-theme-toggle" class="deck-btn" aria-label="Toggle theme" title="Toggle dark / light mode">
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
          <button id="deck-fullscreen-toggle" class="deck-btn" aria-label="Enter fullscreen" title="Toggle fullscreen (F)">
            <svg class="icon-expand" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 3 21 3 21 9"/>
              <polyline points="9 21 3 21 3 15"/>
              <line x1="21" y1="3" x2="14" y2="10"/>
              <line x1="3" y1="21" x2="10" y2="14"/>
            </svg>
            <svg class="icon-compress" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="4 14 10 14 10 20"/>
              <polyline points="20 10 14 10 14 4"/>
              <line x1="10" y1="14" x2="3" y2="21"/>
              <line x1="21" y1="3" x2="14" y2="10"/>
            </svg>
          </button>
          <a href={`/posts/${post.id}`} class="deck-btn deck-exit" aria-label="Exit presentation" title="Exit presentation (Esc)">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </a>
        </div>
      </header>

      <!-- Progress bar -->
      <div class="progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
        <div id="progress-fill" class="progress-fill"></div>
      </div>

      <!-- Laser pointer dot -->
      <div id="laser-dot" aria-hidden="true"></div>
      <!-- Laser trail canvas -->
      <canvas id="laser-canvas" aria-hidden="true"></canvas>

      <!-- Slides viewport: title slide is pre-rendered, content slides injected by JS -->
      <div id="slides-viewport" class="slides-viewport">
        <div class="slide title-slide" data-slide="0">
          <div class="title-content">
            <p class="title-label">Presentation</p>
            <h1 class="title-h1">{post.data.title}</h1>
            <p class="title-desc">{post.data.description}</p>
            <p class="title-date">{formattedDate}</p>
          </div>
        </div>
        <!-- Content slides injected here by JS -->
      </div>
    </div>

    <script define:vars={{ postSlug: post.id, postTitle: post.data.title }}>
      (function () {
        const source = document.getElementById('content-source');
        const viewport = document.getElementById('slides-viewport');
        const counterEl = document.getElementById('counter');
        const progressFill = document.getElementById('progress-fill');
        const progressTrack = document.querySelector('.progress-track');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const deckHeading = document.getElementById('deck-heading');

        // ── Collect groups as HTML strings (enables rebuild on toggle) ──
        // Split content at every <h2>; skip bare <hr> separators
        const groups = [];
        let cur = { heading: '', id: '', htmls: [] };

        for (const child of [...source.children]) {
          if (child.tagName === 'H2') {
            if (cur.heading || cur.htmls.length) groups.push(cur);
            cur = { heading: child.textContent.trim(), id: child.id || '', htmls: [] };
          } else if (child.tagName !== 'HR') {
            cur.htmls.push(child.outerHTML);
          }
        }
        if (cur.heading || cur.htmls.length) groups.push(cur);
        source.remove();

        // ── Split state (persisted) ───────────────────────────────────
        var splitEnabled = localStorage.getItem('deck-split') !== 'false';

        // ── Auto-split overflowing slides ─────────────────────────────
        function splitOverflow() {
          const toCheck = [...viewport.querySelectorAll('.slide:not(.title-slide)')];
          for (const slide of toCheck) {
            const body = slide.querySelector('.slide-body');
            if (!body || body.scrollHeight <= body.clientHeight) continue;

            const sectionHeading = slide.dataset.heading || '';
            const children = [...body.children];
            body.innerHTML = '';

            let currentSlide = slide;
            let currentBody = body;

            for (let i = 0; i < children.length; i++) {
              const child = children[i];
              // A "heading" is H3/H4 OR a <p> whose sole child is a <strong> (bold-only paragraph heading)
              const isBoldOnlyP = child.tagName === 'P' && child.children.length === 1 && child.firstElementChild?.tagName === 'STRONG' && child.textContent?.trim() === child.firstElementChild?.textContent?.trim();
              const isHeading = child.tagName === 'H3' || child.tagName === 'H4' || isBoldOnlyP;
              const hadContent = currentBody.children.length > 0;
              currentBody.appendChild(child);

              if (!hadContent || currentBody.scrollHeight <= currentBody.clientHeight) {
                continue; // fits fine, nothing to do
              }

              // Overflow detected. Find the best split point (a heading boundary).
              currentBody.removeChild(child);

              let toMove = [];
              if (isHeading) {
                // The overflowing child itself is a heading — split right before it.
                // toMove stays empty; new slide will start with this child.
              } else {
                // Backtrack: find the last H3/H4 or bold-only-p in currentBody
                // (at index >= 1 so the current slide doesn't end up empty) and split before it.
                const inBody = [...currentBody.children];
                for (let j = inBody.length - 1; j >= 1; j--) {
                  const el = inBody[j];
                  const elIsBoldOnlyP = el.tagName === 'P' && el.children.length === 1 && el.firstElementChild?.tagName === 'STRONG' && el.textContent?.trim() === el.firstElementChild?.textContent?.trim();
                  if (el.tagName === 'H3' || el.tagName === 'H4' || elIsBoldOnlyP) {
                    toMove = inBody.slice(j);
                    toMove.forEach(n => currentBody.removeChild(n));
                    break;
                  }
                }
                // If no heading found to backtrack to, toMove stays empty and we
                // split at the overflow element (fallback, avoids orphaned heading).
              }

              // Mark current slide and create continuation
              currentSlide.dataset.hasMore = 'true';
              const contSlide = document.createElement('div');
              contSlide.className = 'slide';
              contSlide.dataset.heading = sectionHeading;
              contSlide.dataset.continuation = 'true';
              const contBody = document.createElement('div');
              contBody.className = 'slide-body';
              contSlide.appendChild(contBody);
              currentSlide.after(contSlide);
              currentSlide = contSlide;
              currentBody = contBody;

              // Move backtracked elements (heading + its siblings) then the overflow child
              toMove.forEach(n => currentBody.appendChild(n));
              currentBody.appendChild(child);
            }
          }

          // Assign group IDs to all original (non-continuation) slides that were split
          var groupCounter = 0;
          viewport.querySelectorAll('.slide[data-has-more]').forEach(function (slide) {
            if (!slide.dataset.splitGroup) {
              groupCounter++;
              // Propagate the group ID to all siblings in the chain
              slide.dataset.splitGroup = 'g' + groupCounter;
              let next = slide.nextElementSibling;
              while (next && next.dataset.continuation === 'true' && !next.dataset.splitGroup) {
                next.dataset.splitGroup = 'g' + groupCounter;
                next = next.nextElementSibling;
              }
            }
          });

          // Count members per group
          var groupSizes = {};
          viewport.querySelectorAll('.slide[data-split-group]').forEach(function (slide) {
            var g = slide.dataset.splitGroup;
            groupSizes[g] = (groupSizes[g] || 0) + 1;
          });
          var groupPartIndex = {};

          // Inject continuation badges with n/total numbering
          viewport.querySelectorAll('.slide[data-has-more], .slide[data-continuation]').forEach(function (slide) {
            var g = slide.dataset.splitGroup;
            var total = groupSizes[g] || 1;
            groupPartIndex[g] = (groupPartIndex[g] || 0) + 1;
            var part = groupPartIndex[g];
            var numLabel = part + '\u202f/\u202f' + total; // e.g. "1 / 3"

            if (slide.dataset.continuation === 'true') {
              var topBadge = document.createElement('div');
              topBadge.className = 'slide-badge slide-badge--from';
              topBadge.textContent = '\u2190 cont\u2019d \u00b7 ' + numLabel;
              slide.insertBefore(topBadge, slide.querySelector('.slide-body'));
            }

            if (slide.dataset.hasMore === 'true') {
              var botBadge = document.createElement('div');
              botBadge.className = 'slide-badge slide-badge--more';
              botBadge.textContent = numLabel + ' \u00b7 cont\u2019d \u2192';
              slide.appendChild(botBadge);
            }
          });
        }

        // ── Build / rebuild content slides ────────────────────────────
        function buildContentSlides() {
          [...viewport.querySelectorAll('.slide:not(.title-slide)')].forEach(function (s) { s.remove(); });

          groups.forEach(function ({ heading, id, htmls }) {
            const slide = document.createElement('div');
            slide.className = 'slide';
            slide.dataset.heading = heading;
            if (id) slide.dataset.anchor = id;

            const body = document.createElement('div');
            body.className = 'slide-body';
            body.innerHTML = htmls.join('');
            slide.appendChild(body);
            viewport.appendChild(slide);
          });

          // ── End slide ─────────────────────────────────────────────
          const endSlide = document.createElement('div');
          endSlide.className = 'slide end-slide';
          endSlide.dataset.heading = '';

          const endContent = document.createElement('div');
          endContent.className = 'end-content';

          const endOrnament = document.createElement('div');
          endOrnament.className = 'end-ornament';
          endOrnament.setAttribute('aria-hidden', 'true');
          const lineA = document.createElement('span'); lineA.className = 'end-ornament-line';
          const diamond = document.createElement('span'); diamond.className = 'end-ornament-diamond';
          const lineB = document.createElement('span'); lineB.className = 'end-ornament-line';
          endOrnament.appendChild(lineA); endOrnament.appendChild(diamond); endOrnament.appendChild(lineB);

          const endEyebrow = document.createElement('p');
          endEyebrow.className = 'end-eyebrow';
          endEyebrow.textContent = 'End of Presentation';

          const endHeading = document.createElement('h2');
          endHeading.className = 'end-heading';
          endHeading.textContent = 'The End';

          const endSubtitle = document.createElement('p');
          endSubtitle.className = 'end-subtitle';
          endSubtitle.textContent = postTitle;

          const endLink = document.createElement('a');
          endLink.className = 'end-link';
          endLink.href = '/posts/' + postSlug;
          endLink.textContent = 'Read the article →';

          endContent.appendChild(endOrnament);
          endContent.appendChild(endEyebrow);
          endContent.appendChild(endHeading);
          endContent.appendChild(endSubtitle);
          endContent.appendChild(endLink);
          endSlide.appendChild(endContent);
          viewport.appendChild(endSlide);
        }

        // ── Navigation ───────────────────────────────────────────────
        var slides = [];
        var idx = 0;

        function goTo(i) {
          const from = slides[idx];
          idx = Math.max(0, Math.min(i, slides.length - 1));
          const to = slides[idx];

          if (from !== to) {
            from.classList.remove('active');
            to.classList.add('active');
            const body = to.querySelector('.slide-body');
            if (body) body.scrollTop = 0;
          }

          deckHeading.textContent = slides[idx].dataset.heading || '';
          counterEl.textContent = (idx + 1) + ' / ' + slides.length;

          const pct = slides.length > 1 ? (idx / (slides.length - 1)) * 100 : 100;
          progressFill.style.width = pct + '%';
          progressTrack.setAttribute('aria-valuenow', Math.round(pct));

          prevBtn.disabled = idx === 0;
          nextBtn.disabled = idx === slides.length - 1;
        }

        function initNav() {
          slides = [...viewport.querySelectorAll('.slide')];
          slides.forEach(function (s) { s.classList.remove('active'); });
          idx = 0;
          slides[0].classList.add('active');
          goTo(0);
        }

        // Initial build (nav works immediately; split fires after mermaid renders below)
        buildContentSlides();
        initNav();

        prevBtn.addEventListener('click', () => goTo(idx - 1));
        nextBtn.addEventListener('click', () => goTo(idx + 1));

        // ── Anchor link navigation ───────────────────────────────────
        function findSlideByAnchor(hash) {
          if (!hash) return { index: -1, el: null };
          var anchor = hash.replace(/^#/, '');
          for (var i = 0; i < slides.length; i++) {
            // Match slide's own anchor (from H2 id)
            if (slides[i].dataset.anchor === anchor) return { index: i, el: null };
            // Match any element with that id inside the slide
            var el = slides[i].querySelector('#' + CSS.escape(anchor));
            if (el) return { index: i, el: el };
          }
          return { index: -1, el: null };
        }

        function goToAnchor(hash) {
          var result = findSlideByAnchor(hash);
          if (result.index < 0) return;
          goTo(result.index);
          // Scroll to the exact element inside the slide body
          if (result.el) {
            requestAnimationFrame(function () {
              result.el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
          }
        }

        // Intercept clicks on anchor links within slides
        viewport.addEventListener('click', function (e) {
          var link = e.target.closest('a[href^="#"]');
          if (!link) return;
          var result = findSlideByAnchor(link.getAttribute('href'));
          if (result.index >= 0) {
            e.preventDefault();
            goTo(result.index);
            if (result.el) {
              requestAnimationFrame(function () {
                result.el.scrollIntoView({ behavior: 'smooth', block: 'start' });
              });
            }
          }
        });

        // Jump to slide matching URL hash on load
        if (window.location.hash) goToAnchor(window.location.hash);

        document.addEventListener('keydown', (e) => {
          const tag = (document.activeElement && document.activeElement.tagName) || '';
          if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
          if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); goTo(idx - 1); }
          if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') { e.preventDefault(); goTo(idx + 1); }
          if (e.key === 'Escape') {
            if (document.fullscreenElement) {
              document.exitFullscreen();
            } else {
              window.location.href = '/posts/' + postSlug;
            }
          }
          if (e.key === 'f' || e.key === 'F') { toggleFullscreen(); }
          if (e.key === 'l' || e.key === 'L') { setLaser(!laserActive); }
        });

        // Touch/swipe support
        let swipeX = null;
        document.addEventListener('touchstart', function (e) { swipeX = e.touches[0].clientX; }, { passive: true });
        document.addEventListener('touchend', function (e) {
          if (swipeX === null) return;
          var dx = swipeX - e.changedTouches[0].clientX;
          if (Math.abs(dx) > 50) { dx > 0 ? goTo(idx + 1) : goTo(idx - 1); }
          swipeX = null;
        }, { passive: true });

        // ── Mermaid rendering ────────────────────────────────────────
        var mermaidModule = null;
        var originals = new Map();

        async function renderMermaid() {
          var diagrams = document.querySelectorAll('.mermaid');
          if (!diagrams.length) return;

          diagrams.forEach(function (el) {
            if (!originals.has(el)) originals.set(el, el.textContent || '');
          });
          diagrams.forEach(function (el) { el.classList.add('mermaid-loading'); });

          await new Promise(function (r) { requestAnimationFrame(function () { requestAnimationFrame(r); }); });

          if (!mermaidModule) {
            mermaidModule = (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;
          }
          var mermaid = mermaidModule;
          var isDark = document.documentElement.dataset.theme === 'dark';

          diagrams.forEach(function (el) {
            var src = originals.get(el);
            if (src) { el.innerHTML = src; el.removeAttribute('data-processed'); }
          });

          mermaid.initialize({
            startOnLoad: false,
            theme: isDark ? 'dark' : 'base',
            fontFamily: 'var(--font-body)',
            themeVariables: isDark ? {} : {
              primaryColor: '#dce0e5', primaryTextColor: '#303840', primaryBorderColor: '#525d68',
              lineColor: '#525d68', secondaryColor: '#edf0f3', tertiaryColor: '#f5f6f8',
              textColor: '#303840', nodeTextColor: '#303840', mainBkg: '#dce0e5',
              nodeBorder: '#525d68', clusterBkg: '#edf0f3', clusterBorder: '#c5cad2',
              edgeLabelBackground: '#edf0f3', fontFamily: 'var(--font-body)',
              git0: '#3d6aa8', git1: '#d45d00', git2: '#2a8c6a', git3: '#8b5cc4',
              git4: '#c4483e', git5: '#0d7d8c', git6: '#7a6b30', git7: '#b04d8c',
              gitBranchLabel0: '#ffffff', gitBranchLabel1: '#ffffff', gitBranchLabel2: '#ffffff',
              gitBranchLabel3: '#ffffff', gitBranchLabel4: '#ffffff', gitBranchLabel5: '#ffffff',
              gitBranchLabel6: '#ffffff', gitBranchLabel7: '#ffffff',
              gitInv0: '#ffffff', gitInv1: '#ffffff', gitInv2: '#ffffff', gitInv3: '#ffffff',
              gitInv4: '#ffffff', gitInv5: '#ffffff', gitInv6: '#ffffff', gitInv7: '#ffffff',
              tagLabelColor: '#303840', tagLabelBackground: '#dce0e5', tagLabelBorder: '#525d68',
              commitLabelColor: '#303840', commitLabelBackground: '#edf0f3',
            },
          });

          await mermaid.run({ nodes: [...diagrams] });
          diagrams.forEach(function (el) { el.classList.remove('mermaid-loading'); });
        }

        renderMermaid().then(function () {
          if (!splitEnabled) {
            if (window.location.hash) goToAnchor(window.location.hash);
            return;
          }
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              splitOverflow();
              initNav();
              if (window.location.hash) goToAnchor(window.location.hash);
            });
          });
        });

        new MutationObserver(function (mutations) {
          for (var m of mutations) {
            if (m.attributeName === 'data-theme') { renderMermaid(); break; }
          }
        }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

        // ── Split toggle ──────────────────────────────────────────────
        var splitBtn = document.getElementById('deck-split-toggle');
        if (splitBtn) {
          splitBtn.setAttribute('aria-pressed', splitEnabled ? 'true' : 'false');
          splitBtn.dataset.active = splitEnabled ? 'true' : 'false';
          splitBtn.addEventListener('click', function () {
            splitEnabled = !splitEnabled;
            localStorage.setItem('deck-split', splitEnabled ? 'true' : 'false');
            splitBtn.setAttribute('aria-pressed', splitEnabled ? 'true' : 'false');
            splitBtn.dataset.active = splitEnabled ? 'true' : 'false';
            originals.clear();
            buildContentSlides();
            initNav();
            renderMermaid().then(function () {
              if (!splitEnabled) return;
              requestAnimationFrame(function () {
                requestAnimationFrame(function () {
                  splitOverflow();
                  initNav();
                });
              });
            });
          });
        }

        // ── Fullscreen toggle ─────────────────────────────────────────
        var fsBtn = document.getElementById('deck-fullscreen-toggle');
        function toggleFullscreen() {
          if (!document.fullscreenElement) {
            document.documentElement.requestFullscreen();
          } else {
            document.exitFullscreen();
          }
        }
        fsBtn && fsBtn.addEventListener('click', toggleFullscreen);
        document.addEventListener('fullscreenchange', function () {
          var inFs = !!document.fullscreenElement;
          if (fsBtn) {
            fsBtn.setAttribute('aria-label', inFs ? 'Exit fullscreen' : 'Enter fullscreen');
            fsBtn.dataset.active = inFs ? 'true' : 'false';
          }
          document.documentElement.dataset.fullscreen = inFs ? 'true' : 'false';
        });

        // ── Theme toggle ─────────────────────────────────────────────
        var themeBtn = document.getElementById('deck-theme-toggle');
        themeBtn && themeBtn.addEventListener('click', function () {
          var current = document.documentElement.dataset.theme;
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
        });

        // ── Laser pointer + trail drawing ──────────────────────────────
        var laserBtn = document.getElementById('deck-laser-toggle');
        var laserDot = document.getElementById('laser-dot');
        var laserCanvas = document.getElementById('laser-canvas');
        var laserCtx = laserCanvas ? laserCanvas.getContext('2d') : null;
        var laserActive = false;
        var laserStrokes = [];   // [{points:[{x,y,t},...]}]
        var currentStroke = null;
        var isMouseDown = false;
        var laserRafId = null;
        var LASER_FADE = 2500; // ms until a stroke fully vanishes

        function resizeLaserCanvas() {
          if (!laserCanvas) return;
          laserCanvas.width = window.innerWidth;
          laserCanvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeLaserCanvas);
        resizeLaserCanvas();

        function laserDrawLoop() {
          if (!laserCtx) return;
          var now = Date.now();
          laserCtx.clearRect(0, 0, laserCanvas.width, laserCanvas.height);
          laserStrokes = laserStrokes.filter(function (s) {
            return (now - s.points[s.points.length - 1].t) < LASER_FADE;
          });
          laserStrokes.forEach(function (stroke) {
            var pts = stroke.points;
            if (pts.length < 2) return;
            var age = now - pts[pts.length - 1].t;
            var alpha = Math.max(0, 1 - age / LASER_FADE);
            laserCtx.save();
            laserCtx.globalAlpha = alpha;
            laserCtx.strokeStyle = 'rgba(255, 45, 45, 1)';
            laserCtx.lineWidth = 3;
            laserCtx.lineCap = 'round';
            laserCtx.lineJoin = 'round';
            laserCtx.shadowColor = 'rgba(255, 40, 40, 0.85)';
            laserCtx.shadowBlur = 12;
            laserCtx.beginPath();
            laserCtx.moveTo(pts[0].x, pts[0].y);
            for (var i = 1; i < pts.length; i++) laserCtx.lineTo(pts[i].x, pts[i].y);
            laserCtx.stroke();
            laserCtx.restore();
          });
          if (laserStrokes.length > 0) {
            laserRafId = requestAnimationFrame(laserDrawLoop);
          } else {
            laserRafId = null;
          }
        }

        function startLaserRaf() {
          if (!laserRafId) laserRafId = requestAnimationFrame(laserDrawLoop);
        }

        function setLaser(on) {
          laserActive = on;
          document.documentElement.dataset.laser = on ? 'true' : 'false';
          if (laserDot) laserDot.style.display = on ? 'block' : 'none';
          if (laserBtn) {
            laserBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
            laserBtn.dataset.active = on ? 'true' : 'false';
          }
          if (!on && laserCtx) {
            laserStrokes = [];
            currentStroke = null;
            isMouseDown = false;
            if (laserRafId) { cancelAnimationFrame(laserRafId); laserRafId = null; }
            laserCtx.clearRect(0, 0, laserCanvas.width, laserCanvas.height);
          }
        }

        document.addEventListener('mousedown', function (e) {
          if (!laserActive) return;
          isMouseDown = true;
          currentStroke = { points: [{ x: e.clientX, y: e.clientY, t: Date.now() }] };
          laserStrokes.push(currentStroke);
          startLaserRaf();
        });

        document.addEventListener('mousemove', function (e) {
          if (!laserActive) return;
          if (laserDot) {
            laserDot.style.left = e.clientX + 'px';
            laserDot.style.top = e.clientY + 'px';
          }
          if (!isMouseDown || !currentStroke) return;
          currentStroke.points.push({ x: e.clientX, y: e.clientY, t: Date.now() });
        });

        document.addEventListener('mouseup', function () {
          isMouseDown = false;
          currentStroke = null;
        });

        laserBtn && laserBtn.addEventListener('click', function () {
          setLaser(!laserActive);
        });
      })();
    </script>
  </body>
</html>

