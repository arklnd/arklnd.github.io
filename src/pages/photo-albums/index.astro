---
import Layout from "../../components/Layout.astro";
import photos, { albums } from "../../data/photos";

const isDev = import.meta.env.DEV;

const albumsWithCover = albums.map((album) => {
  const coverSlug = album.coverSlug ?? album.photoSlugs[0];
  const cover = photos.find((p) => p.slug === coverSlug);
  return { album, cover };
});
---

<Layout title="Photo Albums" description="Curated photo albums">
  <article class="albums-page">
    <h1 class="albums-title">Photo Albums</h1>

    {albums.length === 0 && (
      <p class="albums-empty">No albums yet. Add entries to <code>src/data/gallery.ts</code>.</p>
    )}

    <div class="albums-grid">
      {albumsWithCover.map(({ album, cover }) => (
        <a href={`/photo-albums/${album.slug}`} class="album-card">
          <div class="img-loader"></div>
          {cover ? (
            <img
              src={isDev
                ? `/images/gallery/${cover.filename}`
                : `/images/gallery/thumbs/${cover.filename}.webp`}
              alt={cover.caption || album.title}
              loading="lazy"
              decoding="async"
              onload="this.previousElementSibling.style.display='none';this.classList.add('loaded')"
            />
          ) : (
            <div class="album-cover-placeholder"></div>
          )}
          <div class="album-overlay">
            <div class="album-count">{album.photoSlugs.length} photo{album.photoSlugs.length !== 1 ? "s" : ""}</div>
            <h2 class="album-title">{album.title}</h2>
            {album.description && (
              <p class="album-description">{album.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </article>
</Layout>

<style>
  .albums-page {
    padding: var(--space-xl) 0;
  }

  .albums-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--space-xl);
    color: var(--color-text);
  }

  .albums-empty {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  .albums-empty code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: var(--color-code-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .albums-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-lg);
  }

  /* ── Movie-poster card ── */
  .album-card {
    position: relative;
    display: block;
    text-decoration: none;
    aspect-ratio: 2 / 3;
    border-radius: 12px;
    overflow: hidden;
    background: #111;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45), 0 2px 8px rgba(0, 0, 0, 0.3);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .album-card:hover {
    transform: translateY(-5px) scale(1.01);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.55), 0 4px 12px rgba(0, 0, 0, 0.35);
  }

  .album-cover-placeholder {
    position: absolute;
    inset: 0;
    background: #222;
  }

  .img-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #111;
    z-index: 1;
  }

  .img-loader::after {
    content: "";
    width: 28px;
    height: 28px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-top-color: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .album-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.4s ease, transform 0.4s ease;
    opacity: 0;
    transform: scale(1.04);
  }

  .album-card img.loaded {
    opacity: 1;
    transform: scale(1);
  }

  .album-card:hover img {
    transform: scale(1.06);
  }

  /* gradient + text overlay */
  .album-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px 16px 16px;
    background: linear-gradient(
      to bottom,
      transparent 35%,
      rgba(0, 0, 0, 0.35) 60%,
      rgba(0, 0, 0, 0.82) 100%
    );
  }

  .album-count {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 6px;
  }

  .album-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 5px;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }

  .album-description {
    font-family: var(--font-body);
    font-size: 0.72rem;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 600px) {
    .albums-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: var(--space-sm);
    }
  }
</style>
    }
  }
</style>
