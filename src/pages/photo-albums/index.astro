---
import Layout from "../../components/Layout.astro";
import photos, { albums } from "../../data/photos";

const isDev = import.meta.env.DEV || import.meta.env.PUBLIC_LOCAL_DEV === "true";
const base = import.meta.env.BASE_URL;

// Get up to 4 photos per album for the fanned card stack
// Cover photo is placed last so it renders on top (highest z-order)
const albumsWithCards = albums.map((album) => {
  const coverSlug = album.coverSlug ?? album.photoSlugs[0];
  const otherSlugs = album.photoSlugs.filter((s) => s !== coverSlug).slice(0, 3);
  const orderedSlugs = [...otherSlugs, coverSlug];
  const cards = orderedSlugs
    .map((slug) => photos.find((p) => p.slug === slug))
    .filter(Boolean);
  return { album, cards };
});
---

<Layout title="Photo Albums" description="Curated photo albums">
  <article class="albums-page">
    <h1 class="albums-title">Photo Albums</h1>

    <div class="view-toggle">
      <a href={`${base}photo-gallery`} class="toggle-btn">Gallery</a>
      <a href={`${base}photo-albums`} class="toggle-btn active">Albums</a>
    </div>

    {albums.length === 0 && (
      <p class="albums-empty">No albums yet. Add entries to <code>src/data/gallery.ts</code>.</p>
    )}

    <div class="albums-grid">
      {albumsWithCards.map(({ album, cards }) => (
        <a href={`${base}photo-albums/${album.slug}`} class="album-hand">
          <div class="card-fan">
            {cards.map((photo, i) => (
              <div
                class="fan-card"
                style={`--i: ${i}; --total: ${cards.length};`}
              >
                <img
                  src={isDev
                    ? `${base}images/gallery/${photo!.filename}`
                    : `${base}images/gallery/thumbs/${photo!.filename}.webp`}
                  alt={photo!.caption || album.title}
                  loading="lazy"
                  decoding="async"
                  onload="this.classList.add('loaded')"
                />
              </div>
            ))}
          </div>
          <div class="album-info">
            <span class="album-count">{album.photoSlugs.length} photo{album.photoSlugs.length !== 1 ? "s" : ""}</span>
            <h2 class="album-title">{album.title}</h2>
            {album.description && (
              <p class="album-description">{album.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </article>
</Layout>

<style>
  .albums-page {
    padding: var(--space-xl) 0;
  }

  .albums-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--space-md);
    color: var(--color-text);
    text-align: center;
  }

  /* ── Toggle ── */
  .view-toggle {
    display: flex;
    justify-content: center;
    gap: 0;
    margin-bottom: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 4px;
    width: fit-content;
    margin-inline: auto;
  }

  .toggle-btn {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 1.2rem;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-tertiary);
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .toggle-btn:hover {
    color: var(--color-text);
  }

  .toggle-btn.active {
    background: var(--color-border);
    color: var(--color-text);
  }

  .albums-empty {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }

  .albums-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 3rem 2rem;
  }

  /* ── Playing-card hand ── */
  .album-hand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    gap: 1rem;
  }

  .card-fan {
    position: relative;
    width: 180px;
    height: 250px;
    perspective: 600px;
  }

  .fan-card {
    --angle: calc((var(--i) - (var(--total) - 1) / 2) * 8deg);
    --shift: calc((var(--i) - (var(--total) - 1) / 2) * 18px);
    position: absolute;
    inset: 0;
    border-radius: 10px;
    overflow: hidden;
    background: #1a1a1a;
    border: 2px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.5),
      0 1px 4px rgba(0, 0, 0, 0.3);
    transform-origin: bottom center;
    transform: translateX(var(--shift)) rotate(var(--angle));
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s ease;
  }

  .album-hand:hover .fan-card {
    --angle: calc((var(--i) - (var(--total) - 1) / 2) * 14deg);
    --shift: calc((var(--i) - (var(--total) - 1) / 2) * 28px);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.6),
      0 2px 8px rgba(0, 0, 0, 0.4);
  }

  .fan-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .fan-card img.loaded {
    opacity: 1;
  }

  /* ── Album info below the fan ── */
  .album-info {
    text-align: center;
    padding-top: 0.5rem;
  }

  .album-count {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    display: block;
    margin-bottom: 4px;
  }

  .album-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .album-description {
    font-family: var(--font-body);
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--color-text-tertiary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: 220px;
  }

  @media (min-width: 1024px) {
    .albums-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 3.5rem 3rem;
    }
  }

  @media (max-width: 600px) {
    .card-fan {
      width: 150px;
      height: 210px;
    }
  }
</style>
