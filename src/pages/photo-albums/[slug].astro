---
import Layout from "../../components/Layout.astro";
import Reactions from "../../components/Reactions.astro";
import ReactionsBadge from "../../components/ReactionsBadge.astro";
import photos, { albums } from "../../data/photos";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import type { GalleryPhoto } from "../../data/photos";

export const getStaticPaths = (() => {
  return albums.map((album) => ({
    params: { slug: album.slug },
    props: { album },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { album } = Astro.props as Props;

const albumPhotos: GalleryPhoto[] = album.photoSlugs
  .map((slug) => photos.find((p) => p.slug === slug))
  .filter((p): p is GalleryPhoto => p !== undefined);

const isDev = import.meta.env.DEV;
const siteUrl = Astro.site?.origin || "https://arijitk.in";
const coverPhoto = album.coverSlug
  ? albumPhotos.find((p) => p.slug === album.coverSlug) ?? albumPhotos[0]
  : albumPhotos[0];
const ogImage = coverPhoto
  ? `${siteUrl}/images/gallery/og/${coverPhoto.filename}.jpg`
  : undefined;

// ── SEO: combine album + photo keywords (deduplicated) ──
const uniquePlaces = [...new Set(albumPhotos.map((p) => p.place).filter(Boolean))];
const uniqueCaptions = [...new Set(albumPhotos.map((p) => p.caption).filter(Boolean))];
const photoTags = albumPhotos.flatMap((p) => p.tags ?? []);
const allKeywords = [
  album.title,
  ...(album.tags ?? []),
  ...(album.location ? [album.location] : []),
  ...photoTags,
  ...uniquePlaces,
  ...uniqueCaptions,
  "photo album",
  "photography",
  "Arijit Kundu",
];
const keywords = [...new Set(allKeywords.map((k) => k.toLowerCase()))].join(", ");

const albumDescription =
  album.description ??
  `${album.title} — A photo album with ${albumPhotos.length} photos${uniquePlaces.length ? ` from ${uniquePlaces.join(", ")}` : ""}.`;

const albumJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: album.title,
  description: albumDescription,
  url: `${siteUrl}/photo-albums/${album.slug}`,
  numberOfItems: albumPhotos.length,
  ...(album.date && { datePublished: album.date }),
  ...(album.location && { contentLocation: { "@type": "Place", name: album.location } }),
  ...(album.tags?.length && { keywords: album.tags.join(", ") }),
  author: { "@type": "Person", name: "Arijit Kundu" },
  ...(ogImage ? { image: ogImage } : {}),
});
---

<Layout
  title={album.title}
  description={albumDescription}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <meta name="keywords" content={keywords} />
    <script type="application/ld+json" set:html={albumJsonLd} />
  </Fragment>
  <article class="album-page">

    <!-- ── Cinematic hero ── -->
    <div class="album-hero">
      <div class="hero-img-wrap">
        {coverPhoto && (
          <img
            class="hero-bg"
            src={isDev
              ? `/images/gallery/${coverPhoto.filename}`
              : `/images/gallery/display/${coverPhoto.filename}.webp`}
            alt=""
            aria-hidden="true"
            loading="eager"
            decoding="async"
          />
        )}
        <div class="hero-vignette"></div>
      </div>
      <div class="hero-content">
        <a href="/photo-albums" class="back-link">&larr; Albums</a>
        <div class="hero-meta">
          <h1 class="hero-title">{album.title}</h1>
          {album.description && (
            <p class="hero-description">{album.description}</p>
          )}
          <span class="hero-count">{albumPhotos.length} photo{albumPhotos.length !== 1 ? "s" : ""}</span>
          {coverPhoto && (
            <div class="hero-reactions">
              <Reactions slug={`photo:${coverPhoto.slug}`} />
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- ── Photo grid ── -->
    <div class="gallery-grid">
      {albumPhotos.map((photo) => (
        <figure class="gallery-item">
          <div class="gallery-img-wrap">
            <a href={`/photo-gallery/${photo.slug}`}>
              <div class="img-loader"></div>
              <img
                src={isDev
                  ? `/images/gallery/${photo.filename}`
                  : `/images/gallery/thumbs/${photo.filename}.webp`}
                alt={photo.alt || photo.caption}
                loading="lazy"
                decoding="async"
                onload="this.previousElementSibling.style.display='none';this.classList.add('loaded')"
              />
            </a>
            <div class="gallery-reactions">
              <ReactionsBadge slug={`photo:${photo.slug}`} />
            </div>
            {(photo.caption || photo.place) && (
              <div class="gallery-overlay">
                <figcaption class="gallery-caption">
                  {photo.place && <span class="caption-place">{photo.place}</span>}
                  <span class="caption-text">{photo.caption}</span>
                </figcaption>
              </div>
            )}
          </div>
        </figure>
      ))}
    </div>

  </article>
</Layout>

<style>
  .album-page {
    padding-bottom: var(--space-xl);
  }

  /* ── Full-bleed cinematic hero ── */
  .album-hero {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    height: clamp(260px, 56vw, 780px);
    background: #060606;
    margin-bottom: var(--space-xl);
  }

  .hero-img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: brightness(0.75);
    transform: scale(1.02);
    transition: transform 8s ease;
  }

  .album-hero:hover .hero-img-wrap .hero-bg {
    transform: scale(1.06);
  }

  /* layered vignette — dark edges, deep bottom for text */
  .hero-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(0,0,0,0.2) 0%, transparent 70%),
      linear-gradient(to bottom, rgba(0,0,0,0.075) 0%, transparent 40%, rgba(0,0,0,0.325) 70%, rgba(0,0,0,0.46) 100%);
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 28px 40px 36px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.15s ease;
    width: fit-content;
  }

  .back-link:hover {
    color: #fff;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .hero-count {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .hero-title {
    font-family: "Bebas Neue", var(--font-heading);
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 400;
    line-height: 1;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.6), 0 0 80px rgba(0, 0, 0, 0.3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    max-width: 18ch;
  }

  .hero-description {
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 1.5vw, 1rem);
    color: rgba(255, 255, 255, 0.65);
    max-width: 50ch;
    line-height: 1.5;
    margin: 0;
  }

  .hero-reactions {
    margin-top: 12px;
  }

  /* Override Reactions component colours for the dark hero */
  .hero-reactions :global(.reaction-add-btn) {
    color: rgba(255, 255, 255, 0.7);
    border-color: rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(6px);
  }

  .hero-reactions :global(.reaction-add-btn:hover) {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.18);
  }

  .hero-reactions :global(.reaction-btn) {
    color: rgba(255, 255, 255, 0.85);
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(6px);
  }

  .hero-reactions :global(.reaction-btn:hover),
  .hero-reactions :global(.reaction-btn.reaction-mine) {
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.22);
  }

  /* ── Photo grid ── */
  .gallery-grid {
    columns: 4 240px;
    column-gap: var(--space-md);
  }

  .gallery-item {
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 1.5%;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.32), 0 2px 6px rgba(0, 0, 0, 0.18);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    break-inside: avoid;
    margin-bottom: var(--space-md);
    transform: rotate(var(--rot, 0deg));
    position: relative;
  }

  .gallery-item:nth-child(7n+1) { --rot: -1.8deg; margin-top: 10px; }
  .gallery-item:nth-child(7n+2) { --rot: 2.4deg; margin-top: 0px; }
  .gallery-item:nth-child(7n+3) { --rot: -0.5deg; margin-top: 18px; }
  .gallery-item:nth-child(7n+4) { --rot: 1.6deg; margin-top: 4px; }
  .gallery-item:nth-child(7n+5) { --rot: -2.8deg; margin-top: 14px; }
  .gallery-item:nth-child(7n+6) { --rot: 0.9deg; margin-top: 8px; }
  .gallery-item:nth-child(7n+7) { --rot: -1.2deg; margin-top: 22px; }

  .gallery-item:hover {
    transform: rotate(0deg) translateY(-4px) scale(1.03);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.25), 0 4px 10px rgba(0, 0, 0, 0.12);
    z-index: 2;
  }

  .gallery-img-wrap {
    position: relative;
    line-height: 0;
  }

  .gallery-img-wrap a {
    display: block;
  }

  .img-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    z-index: 1;
  }

  .img-loader::after {
    content: "";
    width: 28px;
    height: 28px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-link);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s ease;
    opacity: 0;
  }

  .gallery-item img.loaded {
    opacity: 1;
  }

  .gallery-item:hover img {
    opacity: 0.92;
  }

  .gallery-caption {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.3;
  }

  .caption-text {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #fff;
  }

  .caption-place {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 10px 10px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    pointer-events: none;
  }

  .gallery-reactions {
    position: absolute;
    top: 6px;
    right: 6px;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .hero-content {
      padding: 20px 20px 28px;
    }

    .gallery-grid {
      columns: 2 150px;
      column-gap: var(--space-sm);
    }

    .gallery-item {
      margin-bottom: var(--space-sm);
    }
  }
</style>
