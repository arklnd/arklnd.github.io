---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
---

<Layout title="Offline" description="You are currently offline.">
  <section class="offline">
    <Heading as="h1">You're Offline</Heading>
    <p>It looks like you've lost your internet connection.</p>
    <p>Previously visited pages may still be available from the cache.</p>
    <a href="/">← Try going home</a>
  </section>
</Layout>

<style>
  .offline {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 1rem;
  }

  .offline p {
    font-size: 1.2rem;
    color: var(--text-muted, #888);
  }

  .offline a {
    color: var(--accent, #3d6aa8);
    text-decoration: none;
    font-weight: 500;
  }

  .offline a:hover {
    text-decoration: underline;
  }
</style>
