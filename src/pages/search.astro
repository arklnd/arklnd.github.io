---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
---

<Layout title="Search — Arijit's Blog" description="Search posts on Arijit's Blog.">
  <section class="search-page">
    <Heading as="h1">Search</Heading>
    <div class="search-input-wrap">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder="Search posts..."
        autocomplete="off"
        autofocus
      />
    </div>
    <p id="result-count" class="result-count" hidden></p>
    <ul id="search-results" class="search-results"></ul>
    <p id="search-empty" class="search-empty" hidden>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        <line x1="8" y1="11" x2="14" y2="11"/>
      </svg>
      No posts found.
    </p>
  </section>
</Layout>

<script>
  interface SearchEntry {
    slug: string;
    title: string;
    description: string;
    date: string;
    body: string;
  }

  // Module-level cache — survives View Transition navigations
  let index: SearchEntry[] = [];
  let loaded = false;

  async function loadIndex(): Promise<void> {
    if (loaded) return;
    const res = await fetch("/search-index.json");
    index = await res.json();
    loaded = true;
  }

  function search(query: string): SearchEntry[] {
    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
    if (terms.length === 0) return index;
    return index.filter((entry) => {
      const haystack = `${entry.title} ${entry.description} ${entry.body}`.toLowerCase();
      return terms.every((term) => haystack.includes(term));
    });
  }

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  }

  function readingTime(body: string): string {
    const words = body.trim().split(/\s+/).length;
    const mins = Math.max(1, Math.round(words / 200));
    return `${mins} min read`;
  }

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function highlight(text: string, terms: string[]): string {
    const escaped = escapeHtml(text);
    if (!terms.length) return escaped;
    const pattern = new RegExp(
      `(${terms.map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")).join("|")})`,
      "gi"
    );
    return escaped.replace(pattern, "<mark>$1</mark>");
  }

  function renderResults(
    resultsList: HTMLUListElement,
    emptyMsg: HTMLParagraphElement,
    countEl: HTMLParagraphElement,
    results: SearchEntry[],
    query: string
  ): void {
    resultsList.innerHTML = "";
    const isEmptyQuery = query.trim() === "";
    const terms = isEmptyQuery ? [] : query.toLowerCase().split(/\s+/).filter(Boolean);

    if (!isEmptyQuery && results.length === 0) {
      emptyMsg.hidden = false;
      countEl.hidden = true;
      return;
    }

    emptyMsg.hidden = true;

    if (!isEmptyQuery) {
      countEl.hidden = false;
      countEl.textContent = `${results.length} result${results.length === 1 ? "" : "s"}`;
    } else {
      countEl.hidden = true;
    }

    for (const entry of results) {
      const li = document.createElement("li");
      li.className = "search-result-item";
      li.innerHTML = `
        <a href="/posts/${entry.slug}">
          <span class="result-title">${highlight(entry.title, terms)}</span>
          <span class="result-description">${highlight(entry.description, terms)}</span>
          <span class="result-meta">
            <time datetime="${entry.date}">${formatDate(entry.date)}</time>
            <span class="result-dot" aria-hidden="true">·</span>
            <span class="result-reading-time">${readingTime(entry.body)}</span>
          </span>
        </a>
      `;
      resultsList.appendChild(li);
    }
  }

  // Re-run after every View Transition navigation (and on first load)
  document.addEventListener("astro:page-load", () => {
    const input = document.getElementById("search-input") as HTMLInputElement | null;
    if (!input) return; // not on the search page

    const resultsList = document.getElementById("search-results") as HTMLUListElement;
    const emptyMsg = document.getElementById("search-empty") as HTMLParagraphElement;
    const countEl = document.getElementById("result-count") as HTMLParagraphElement;

    let debounceTimer: ReturnType<typeof setTimeout>;

    input.addEventListener("input", () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async () => {
        await loadIndex();
        renderResults(resultsList, emptyMsg, countEl, search(input.value), input.value);
      }, 150);
    });

    // Support ?q= param and show all posts by default
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get("q") ?? "";
    if (initialQuery) input.value = initialQuery;

    loadIndex().then(() => {
      renderResults(resultsList, emptyMsg, countEl, search(initialQuery), initialQuery);
    });
  });
</script>

<style>
  .search-page {
    max-width: var(--width-content);
  }

  .search-input-wrap {
    position: relative;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .search-icon {
    position: absolute;
    left: var(--space-md);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-tertiary);
    pointer-events: none;
  }

  #search-input {
    width: 100%;
    font-family: var(--font-heading);
    font-size: 1rem;
    padding: var(--space-sm) var(--space-md) var(--space-sm) 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  #search-input:focus {
    border-color: var(--color-link);
    box-shadow: 0 0 0 3px rgba(61, 106, 168, 0.12);
  }

  #search-input::placeholder {
    color: var(--color-text-tertiary);
  }

  /* result-count is in the Astro template, scoped attr present */
  .result-count {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-md);
  }

  /* search-empty is in the Astro template — use display:none for [hidden]
     so the UA rule isn't overridden by display:flex */
  .search-empty {
    display: none;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    color: var(--color-text-tertiary);
    padding: var(--space-2xl) 0;
  }

  .search-empty:not([hidden]) {
    display: flex;
  }

  /* ---------- styles for dynamically-created result items ----------
     Astro scopes CSS to [data-astro-cid-*] on the element itself, but
     JS-created li/span/time nodes never get that attribute.
     Use :global() so the selectors are emitted without the scoping attr. */
  :global(.search-results) {
    list-style: none;
    padding: 0;
  }

  :global(.search-result-item) {
    border-bottom: 1px solid var(--color-border);
  }

  :global(.search-result-item:first-child) {
    border-top: 1px solid var(--color-border);
  }

  :global(.search-result-item a) {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) var(--space-sm);
    margin: 0 calc(-1 * var(--space-sm));
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.15s ease;
  }

  :global(.search-result-item a:hover) {
    background: var(--color-surface);
  }

  :global(.search-result-item a:hover .result-title) {
    color: var(--color-link);
  }

  :global(.result-title) {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  :global(.result-description) {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  :global(.result-meta) {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  :global(.result-dot) {
    opacity: 0.5;
  }

  :global(mark) {
    background-color: rgba(61, 106, 168, 0.15);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }

  :global([data-theme="dark"] mark) {
    background-color: rgba(100, 160, 240, 0.2);
  }
</style>
