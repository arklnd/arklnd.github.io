---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import ReactionsBadge from "../components/ReactionsBadge.astro";
// Import PostCard so its global styles are included in the page
import "../components/PostCard.astro";
---

<Layout title="Search — Arijit's Blog" description="Search posts on Arijit's Blog.">
  <section class="search-page">
    <Heading as="h1">Search</Heading>
    <div class="search-input-wrap" role="search">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <label for="search-input" class="sr-only">Search posts</label>
      <input
        type="search"
        id="search-input"
        placeholder="Search posts..."
        autocomplete="off"
        autofocus
      />
    </div>
    <p id="result-count" class="result-count" aria-live="polite" aria-atomic="true" hidden></p>
    <ul id="search-results" class="search-results" aria-label="Search results"></ul>
    {/* Hidden ReactionsBadge to include its script + styles */}
    <ReactionsBadge slug="" />
    <p id="search-empty" class="search-empty" aria-live="polite" hidden>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        <line x1="8" y1="11" x2="14" y2="11"/>
      </svg>
      No posts found.
    </p>
  </section>
</Layout>

<script>
  interface SearchEntry {
    slug: string;
    title: string;
    description: string;
    date: string;
    tags: string[];
    body: string;
  }

  // Module-level cache — survives View Transition navigations
  let index: SearchEntry[] = [];
  let loaded = false;

  async function loadIndex(): Promise<void> {
    if (loaded) return;
    const res = await fetch("/search-index.json");
    index = await res.json();
    loaded = true;
  }

  function search(query: string): SearchEntry[] {
    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
    if (terms.length === 0) return index;
    return index.filter((entry) => {
      const haystack = `${entry.title} ${entry.description} ${entry.tags.join(" ")} ${entry.body}`.toLowerCase();
      return terms.every((term) => haystack.includes(term));
    });
  }

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  }

  function wordCount(body: string): number {
    return body.trim().split(/\s+/).filter(Boolean).length;
  }

  function readingTime(words: number): string {
    const mins = Math.max(1, Math.round(words / 200));
    return `${mins} min read`;
  }

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function highlight(text: string, terms: string[]): string {
    const escaped = escapeHtml(text);
    if (!terms.length) return escaped;
    const pattern = new RegExp(
      `(${terms.map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")).join("|")})`,
      "gi"
    );
    return escaped.replace(pattern, "<mark>$1</mark>");
  }

  function renderResults(
    resultsList: HTMLUListElement,
    emptyMsg: HTMLParagraphElement,
    countEl: HTMLParagraphElement,
    results: SearchEntry[],
    query: string
  ): void {
    resultsList.innerHTML = "";
    const isEmptyQuery = query.trim() === "";
    const terms = isEmptyQuery ? [] : query.toLowerCase().split(/\s+/).filter(Boolean);

    if (!isEmptyQuery && results.length === 0) {
      emptyMsg.hidden = false;
      countEl.hidden = true;
      return;
    }

    emptyMsg.hidden = true;

    if (!isEmptyQuery) {
      countEl.hidden = false;
      countEl.textContent = `${results.length} result${results.length === 1 ? "" : "s"}`;
    } else {
      countEl.hidden = true;
    }

    for (const entry of results) {
      const tagsHtml = entry.tags.length > 0
        ? `<div class="pc-tags">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-tags-icon" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            ${entry.tags.slice(0, 3).map((t) => `<span class="pc-tag">${escapeHtml(t)}</span>`).join("")}
            ${entry.tags.length > 3 ? `<span class="pc-tag pc-tag--more">+${entry.tags.length - 3}</span>` : ""}
           </div>`
        : "";

      const words = wordCount(entry.body);
      const li = document.createElement("li");
      li.className = "pc pc--list";
      li.innerHTML = `
        <a href="/posts/${entry.slug}" class="pc-link">
          <div class="pc-body">
            <span class="pc-title">${highlight(entry.title, terms)}</span>
            <span class="reaction-badge" data-slug="${entry.slug}"></span>
            <span class="pc-desc">${highlight(entry.description, terms)}</span>
          </div>
          <div class="pc-footer">
            <span class="pc-meta">
              <time datetime="${entry.date}">${formatDate(entry.date)}</time>
              &mdash; ${readingTime(words)}
              &mdash; ${words.toLocaleString()} words
            </span>
          </div>
          ${tagsHtml}
        </a>
      `;
      resultsList.appendChild(li);
    }

    // Trigger ReactionsBadge to populate badges on JS-rendered cards
    document.dispatchEvent(new Event("reactions:render-badges"));
  }

  // Re-run after every View Transition navigation (and on first load)
  document.addEventListener("astro:page-load", () => {
    const input = document.getElementById("search-input") as HTMLInputElement | null;
    if (!input) return; // not on the search page

    const resultsList = document.getElementById("search-results") as HTMLUListElement;
    const emptyMsg = document.getElementById("search-empty") as HTMLParagraphElement;
    const countEl = document.getElementById("result-count") as HTMLParagraphElement;

    let debounceTimer: ReturnType<typeof setTimeout>;

    input.addEventListener("input", () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async () => {
        await loadIndex();
        renderResults(resultsList, emptyMsg, countEl, search(input.value), input.value);
      }, 150);
    });

    // Support ?q= param and show all posts by default
    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get("q") ?? "";
    if (initialQuery) input.value = initialQuery;

    loadIndex().then(() => {
      renderResults(resultsList, emptyMsg, countEl, search(initialQuery), initialQuery);
    });
  });
</script>

<style>
  .search-page {
    max-width: var(--width-content);
  }

  .search-input-wrap {
    position: relative;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .search-icon {
    position: absolute;
    left: var(--space-md);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-tertiary);
    pointer-events: none;
  }

  #search-input {
    width: 100%;
    font-family: var(--font-heading);
    font-size: 1rem;
    padding: var(--space-sm) var(--space-md) var(--space-sm) 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-surface);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  #search-input:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: -1px;
  }

  #search-input:focus {
    border-color: var(--color-link);
    box-shadow: 0 0 0 3px rgba(61, 106, 168, 0.12);
  }

  #search-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .result-count {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-md);
  }

  .search-empty {
    display: none;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    color: var(--color-text-tertiary);
    padding: var(--space-2xl) 0;
  }

  .search-empty:not([hidden]) {
    display: flex;
  }

  :global(.search-results) {
    list-style: none;
    padding: 0;
  }
</style>
