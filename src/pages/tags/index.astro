---
import Layout from "../../components/Layout.astro";
import Heading from "../../components/Heading.astro";
import TagPill from "../../components/TagPill.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => import.meta.env.DEV || !data.draft);

// Collect unique tags, sorted alphabetically
const tagSet = new Set<string>();
posts.forEach((post) => {
  post.data.tags.forEach((tag: string) => tagSet.add(tag));
});
const sortedTags = Array.from(tagSet).sort((a, b) => a.localeCompare(b));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Tags — Arijit's Blog",
  "description": "Browse all tags and topics on Arijit's Blog.",
  "url": new URL("/tags", Astro.site).href,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Arijit's Blog",
    "url": Astro.site?.href,
  },
};
---

<Layout title="Tags — Arijit's Blog" description="Browse all tags and topics on Arijit's Blog — software engineering, Git, .NET, security, system design, and more.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="tags-page">
    <Heading as="h1">Tags</Heading>
    <p class="tags-intro">Browse posts by topic. {sortedTags.length} tags across {posts.length} posts.</p>
    <div class="tags-cloud">
      {sortedTags.map((tag) => (
        <TagPill tag={tag} />
      ))}
    </div>
  </section>
</Layout>

<style>
  .tags-page {
    max-width: var(--width-content);
  }

  .tags-intro {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
</style>
