---
import Layout from "../../components/Layout.astro";
import Heading from "../../components/Heading.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  // Collect all unique tags
  const tagSet = new Set<string>();
  posts.forEach((post) => {
    post.data.tags.forEach((tag: string) => tagSet.add(tag));
  });

  return Array.from(tagSet).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const tagUrl = new URL(`/tags/${tag}`, Astro.site).href;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Posts tagged "${tag}" — Arijit's Blog`,
    "description": `All blog posts tagged with "${tag}" on Arijit's Blog.`,
    "url": tagUrl,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Arijit's Blog",
      "url": Astro.site?.href,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": Astro.site?.href,
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Tags",
        "item": new URL("/tags", Astro.site).href,
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": tag,
        "item": tagUrl,
      },
    ],
  },
];
---

<Layout title={`Posts tagged "${tag}" — Arijit's Blog`} description={`All blog posts tagged with "${tag}" on Arijit's Blog.`}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="tag-page">
    <header class="tag-header">
      <a href="/tags" class="back-link" aria-label="Back to all tags">&larr; All Tags</a>
      <Heading as="h1">{tag}</Heading>
      <p class="tag-count">{posts.length} post{posts.length !== 1 ? "s" : ""}</p>
    </header>
    <ul class="post-list" role="list">
      {posts.map((post: any) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <li class="post-item">
            <a href={`/posts/${post.id}`}>
              <span class="post-title">{post.data.title}</span>
              <span class="post-desc">{post.data.description}</span>
              <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</Layout>

<style>
  .tag-page {
    max-width: var(--width-content);
  }

  .tag-header {
    margin-bottom: var(--space-xl);
  }

  .back-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-link);
  }

  .tag-count {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg) var(--space-sm);
    margin: 0 calc(-1 * var(--space-sm));
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.15s ease;
  }

  .post-item a:hover {
    background: var(--color-surface);
  }

  .post-item a:hover .post-title {
    color: var(--color-link);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    transition: color 0.15s ease;
  }

  .post-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-xs);
  }
</style>
