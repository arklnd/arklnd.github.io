---
import Layout from "../../components/Layout.astro";
import Heading from "../../components/Heading.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  // Collect all unique tags
  const tagSet = new Set<string>();
  posts.forEach((post) => {
    post.data.tags.forEach((tag: string) => tagSet.add(tag));
  });

  return Array.from(tagSet).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const tagUrl = new URL(`/tags/${tag}`, Astro.site).href;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Posts tagged "${tag}" — Arijit's Blog`,
    "description": `All blog posts tagged with "${tag}" on Arijit's Blog.`,
    "url": tagUrl,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Arijit's Blog",
      "url": Astro.site?.href,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": Astro.site?.href,
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Tags",
        "item": new URL("/tags", Astro.site).href,
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": tag,
        "item": tagUrl,
      },
    ],
  },
];
---

<Layout title={`Posts tagged "${tag}" — Arijit's Blog`} description={`All blog posts tagged with "${tag}" on Arijit's Blog.`}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="tag-page">
    <header class="tag-header">
      <a href="/tags" class="back-link" aria-label="Back to all tags">&larr; All Tags</a>
      <Heading as="h1">{tag}</Heading>
      <p class="tag-count">{posts.length} post{posts.length !== 1 ? "s" : ""}</p>
    </header>
    <ul class="post-list" role="list">
      {posts.map((post: any) => (
        <PostCard
          slug={post.id}
          variant="list"
          reactions={true}
          showAllTags={true}
        />
      ))}
    </ul>
  </section>
</Layout>

<style>
  .tag-page {
    max-width: var(--width-content);
  }

  .tag-header {
    margin-bottom: var(--space-xl);
  }

  .back-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-link);
  }

  .tag-count {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .post-list {
    list-style: none;
    padding: 0;
  }
</style>
