---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Prose from "../components/Prose.astro";
import projects from "../data/projects";
---

<Layout title="About — Arijit's Blog" description="About Arijit Kundu — software engineer at Hyland Software, building with .NET, Angular, C++, and Python. Read about projects, skills, and contact info.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "name": "About Arijit Kundu",
      "description": "About Arijit Kundu — software engineer, technical blogger, and open-source contributor.",
      "url": new URL("/about", Astro.site).href,
      "inLanguage": "en",
      "isPartOf": {
        "@type": "WebSite",
        "name": "Arijit's Blog",
        "url": Astro.site?.href,
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Arijit Kundu",
      "url": "https://arijitk.in",
      "image": new URL("/images/arijit.kundu.jpg", Astro.site).href,
      "sameAs": [
        "https://linkedin.com/in/a1kundu",
        "https://github.com/a1kundu"
      ],
      "jobTitle": "Software Engineer",
      "worksFor": {
        "@type": "Organization",
        "name": "Hyland Software"
      },
      "knowsAbout": ["C# .NET", "Angular", "Python", "Java", "Kotlin", "C++", "TypeScript", "Git", "Docker", "Azure"],
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": Astro.site?.href,
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "About",
          "item": new URL("/about", Astro.site).href,
        },
      ],
    },
  ])} />
  <section class="about-container">
    <Heading as="h1">About Me</Heading>

    <img src="/images/arijit.kundu.jpg" alt="Arijit Kundu" class="profile-photo" width="180" height="180" />

    <Prose>

      <div class="experience-section">
        <!-- <Heading as="h2">Experience</Heading> -->
        <div class="experience-item">
          <p>I am Arijit Kundu. Being empty-handed is very frustrating for me, it's better to do something than nothing. During my high school years, I discovered that I am loving creating software in C & C++, and websites in PHP. I did few web developement as a freelancer in my locality during my school and college days. That's why after finishing my study, I took a job in the software industry. But the thing is, I am very lazy as well, That's why, I prefer to sit on my chair or lie down on my couch, and try to reduce the burden put on my head by the corporate. And obviously for that corporate pays me well.</p>
          <p>
            Nowadays I usually create stuffs with .NET and Angular. I would not say I am an expert of these, there are more experts in .NET and Angular out there. These are the technologies I am working with daily from the beginning of my professional career. That's why these technologies gradually became my default choice and i gained significant experience in them. There are few other technologies I dabble with occasionally, sometimes it's Python, C or C++, when it suits the topic I am engage with.
          </p>
          <p>
            At Hyland Software, I am involved in developing and maintaining enterprise software solutions using C# .NET and Angular. 
            Collaborating with cross-functional teams to deliver high-quality applications that serve 
            thousands of users worldwide.
          </p>
        </div>
      </div>

      <div class="skills-section">
        <Heading as="h2">Technical Skills</Heading>
        <ul>
          <li><strong>Primary:</strong> C# .NET, Angular</li>
          <li><strong>Languages:</strong> Python, Java, Kotlin, C, C++</li>
          <li><strong>Web:</strong> HTML5, CSS3, JavaScript, TypeScript</li>
          <li><strong>Tools:</strong> Git, SQL Server, Docker, Azure</li>
        </ul>
      </div>

      <div class="projects-section">
        <Heading as="h2">Projects</Heading>
        <div class="projects-grid">
          {projects.map((project) => (
            <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="project-card">
              <div class="project-card-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="project-card-icon">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                <span class="project-card-name">{project.name}</span>
              </div>
              <p class="project-card-desc">{project.description}</p>
              <div class="project-card-tech">
                {project.tech.map((t) => (
                  <span class="tech-tag">{t}</span>
                ))}
              </div>
              <span class="sr-only">(opens in a new tab)</span>
            </a>
          ))}
        </div>
      </div>

      <div class="contact-section">
        <Heading as="h2">Get In Touch</Heading>
        <p>I'm always open to discussing new opportunities, interesting projects, or just having a chat about technology.</p>
        <ul>
          <li>LinkedIn: <a href="https://linkedin.com/in/a1kundu" target="_blank" rel="noopener noreferrer">linkedin.com/in/a1kundu<span class="sr-only"> (opens in a new tab)</span></a></li>
          <li>GitHub: <a href="https://github.com/a1kundu" target="_blank" rel="noopener noreferrer">github.com/a1kundu<span class="sr-only"> (opens in a new tab)</span></a></li>
        </ul>
      </div>
    </Prose>
  </section>
</Layout>

<style>
  .profile-photo {
    border-radius: 50%;
    object-fit: cover;
    display: block;
    margin: 0 auto 1.5rem;
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.28);
  }
  .experience-item h3 {
    margin-bottom: 0.25rem;
  }
  .skills-section ul, .contact-section ul {
    list-style: none;
    padding: 0;
  }
  .skills-section li, .contact-section li {
    margin-bottom: 0.5rem;
  }

  /* ── Projects grid ────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .project-card:hover {
    border-color: color-mix(in srgb, var(--color-link) 40%, var(--color-border));
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
    color: inherit;
  }

  .project-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .project-card-icon {
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .project-card-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-link);
  }

  .project-card-desc {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .project-card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }

  .tech-tag {
    font-family: var(--font-heading);
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 12px;
    background: color-mix(in srgb, var(--color-link) 10%, transparent);
    color: var(--color-link);
    white-space: nowrap;
  }
</style>
