---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Prose from "../components/Prose.astro";
---

<Layout title="About — KintsugiLife" description="About KintsugiLife.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About KintsugiLife",
    "description": "About KintsugiLife.",
    "url": new URL("/about", Astro.site).href,
    "isPartOf": {
      "@type": "WebSite",
      "name": "KintsugiLife",
      "url": Astro.site?.href,
    },
  })} />
  <section class="about-container">
    <Heading as="h1">About KintsugiLife</Heading>

    <Prose>

      <div>KintsugiLife</div>
    </Prose>
  </section>
</Layout>

<style>
  .experience-item h3 {
    margin-bottom: 0.25rem;
  }
  .skills-section ul, .contact-section ul {
    list-style: none;
    padding: 0;
  }
  .skills-section li, .contact-section li {
    margin-bottom: 0.5rem;
  }
</style>
