---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Prose from "../components/Prose.astro";
---

<Layout title="About — Arijit Kundu Blog" description="About Arijit Kundu Blog.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Arijit Kundu Blog",
    "description": "About Arijit Kundu Blog.",
    "url": new URL("/about", Astro.site).href,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Arijit Kundu Blog",
      "url": Astro.site?.href,
    },
  })} />
  <section class="about-container">
    <Heading as="h1">About Me</Heading>
    
    <div class="hero-content">
      <p class="hero-description">
        Passionate software developer with 3.3 years of experience at Hyland Software, 
        specializing in C# .NET and Angular development.
      </p>
    </div>

    <Prose>
      <div class="about-text">
        <p>
          I'm a dedicated software developer with 3.3 years of professional experience at Hyland Software. 
          My expertise lies in building robust applications using C# .NET and creating dynamic user interfaces with Angular.
        </p>
        <p>
          I have a strong foundation in multiple programming languages including Python, Java, Kotlin, C, and C++. 
          I'm passionate about clean code, innovative solutions, and continuous learning in the ever-evolving tech landscape.
        </p>
      </div>

      <div class="experience-section">
        <Heading as="h2">Experience</Heading>
        <div class="experience-item">
          <h3>Software Developer at Hyland Software</h3>
          <p class="date">2021 - Present (3.3 years)</p>
          <p>
            Developing and maintaining enterprise software solutions using C# .NET and Angular. 
            Collaborating with cross-functional teams to deliver high-quality applications that serve 
            thousands of users worldwide.
          </p>
        </div>
      </div>

      <div class="skills-section">
        <Heading as="h2">Technical Skills</Heading>
        <ul>
          <li><strong>Primary:</strong> C# .NET, Angular</li>
          <li><strong>Languages:</strong> Python, Java, Kotlin, C, C++</li>
          <li><strong>Web:</strong> HTML5, CSS3, JavaScript, TypeScript</li>
          <li><strong>Tools:</strong> Git, SQL Server, Docker, Azure</li>
        </ul>
      </div>

      <div class="contact-section">
        <Heading as="h2">Get In Touch</Heading>
        <p>I'm always open to discussing new opportunities, interesting projects, or just having a chat about technology.</p>
        <ul>
          <li>Email: arijit.kundu@hyland.com</li>
          <li>LinkedIn: linkedin.com/in/arikundu9</li>
          <li>GitHub: github.com/arklnd</li>
        </ul>
      </div>
    </Prose>
  </section>
</Layout>

<style>
  .about-container {
    max-width: var(--width-content);
  }
  .hero-description {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .experience-item h3 {
    margin-bottom: 0.25rem;
  }
  .date {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .skills-section ul, .contact-section ul {
    list-style: none;
    padding: 0;
  }
  .skills-section li, .contact-section li {
    margin-bottom: 0.5rem;
  }
</style>
